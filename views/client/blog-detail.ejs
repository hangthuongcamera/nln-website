<%- include('partials/header') %>

<div class="container mx-auto px-4 max-w-7xl mt-6 mb-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary transition-colors"><i class="fa-solid fa-house mr-1"></i> Trang Chủ</a> <i class="fa-solid fa-angle-right mx-2 text-xs"></i>
        <a href="/tin-tuc" class="hover:text-primary transition-colors">Tin Tức & Kinh Nghiệm</a> <i class="fa-solid fa-angle-right mx-2 text-xs"></i>
        <span class="text-gray-800 font-medium line-clamp-1 mt-2 md:mt-0 md:inline"><%= blog.title %></span>
    </nav>

    <div class="flex flex-col lg:flex-row gap-8">
        <!-- Main Content: Article -->
        <div class="w-full lg:w-3/4">
            <article class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
                <h1 class="text-2xl md:text-3xl font-bold text-gray-800 mb-4 leading-snug"><%= blog.title %></h1>
                
                <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500 mb-6 pb-4 border-b border-gray-100">
                    <span><i class="fa-regular fa-calendar text-primary mr-1"></i> <%= new Date(blog.createdAt).toLocaleDateString('vi-VN') %></span>
                    <span><i class="fa-regular fa-folder text-primary mr-1"></i> <%= blog.category || 'Chung' %></span>
                    <span><i class="fa-solid fa-eye text-primary mr-1"></i> Lượt xem: <%= blog.views %></span>
                    <span><i class="fa-solid fa-pen-nib text-primary mr-1"></i> Đăng bởi: <%= (blog.author && blog.author.name) ? blog.author.name : 'Admin Nhất Linh Nhi' %></span>
                </div>

                <!-- Article Body (Rich Text Content) -->
                <div class="prose max-w-none text-gray-700 text-base leading-relaxed mb-8">
                    <%- blog.content %>
                </div>

                <!-- Share & Tags -->
                <div class="mt-8 pt-6 border-t border-gray-100 flex flex-col sm:flex-row justify-between items-center gap-4">
                    <div class="flex items-center gap-2 flex-wrap">
                        <span class="text-sm font-semibold text-gray-700"><i class="fa-solid fa-tags mr-1"></i> Tags:</span>
                        <% if (blog.tags && blog.tags.length > 0) { %>
                            <% blog.tags.forEach(tag => { %>
                                <span class="bg-gray-100 text-gray-600 px-3 py-1 rounded text-xs hover:bg-primary hover:text-white cursor-pointer transition"><%= tag %></span>
                            <% }) %>
                        <% } %>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="text-sm font-semibold text-gray-700">Chia sẻ:</span>
                        <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent('http://nhatlinhnhi.com/tin-tuc/' + blog.slug) %>" target="_blank" class="w-8 h-8 rounded-full bg-blue-600 text-white flex items-center justify-center hover:bg-blue-700 transition"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="#" class="w-8 h-8 rounded-full bg-blue-400 text-white flex items-center justify-center hover:bg-blue-500 transition"><i class="fa-brands fa-twitter"></i></a>
                    </div>
                </div>
            </article>
        </div>
        
        <!-- Sidebar -->
        <aside class="w-full lg:w-1/4 flex flex-col gap-6">
            <div class="bg-white border border-gray-200 rounded-lg p-5 shadow-sm text-center">
                <div class="w-20 h-20 bg-gray-200 rounded-full mx-auto mb-3 overflow-hidden border-2 border-primary">
                    <img src="/img/logo.png" alt="Nhất Linh Nhi" class="w-full h-full object-cover p-2 bg-white">
                </div>
                <h3 class="font-bold text-gray-800 mb-1">Nhất Linh Nhi</h3>
                <p class="text-xs text-gray-500 mb-3">Chuyên phân phối vật tư điện nước công trình uy tín, chất lượng.</p>
                <a href="/danh-muc" class="inline-block bg-primary text-white text-sm px-4 py-1.5 rounded hover:bg-blue-800 transition w-full font-medium">Đến cửa hàng</a>
            </div>

            <% if (featuredBlogs && featuredBlogs.length > 0) { %>
                <div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm">
                    <h2 class="font-bold text-primary mb-4 border-b pb-2 uppercase text-sm"><i class="fa-solid fa-book-open mr-2 text-orange-500"></i>Bài Viết Đáng Chú Ý</h2>
                    <div class="flex flex-col gap-4">
                        <% featuredBlogs.forEach(feat => { %>
                            <a href="/tin-tuc/<%= feat.slug %>" class="flex gap-3 group">
                                <img src="<%= feat.thumbnail || '/img/default-thumbnail.jpg' %>" alt="<%= feat.title %>" class="w-20 h-16 object-cover rounded border border-gray-100 flex-shrink-0">
                                <div>
                                    <h3 class="text-sm font-semibold text-gray-800 group-hover:text-primary line-clamp-2 transition-colors mb-1 leading-tight"><%= feat.title %></h3>
                                    <span class="text-xs text-gray-500"><i class="fa-regular fa-clock mr-1"></i> <%= new Date(feat.createdAt).toLocaleDateString('vi-VN') %></span>
                                </div>
                            </a>
                        <% }) %>
                    </div>
                </div>
            <% } %>
        </aside>
    </div>
</div>

<%- include('partials/footer') %>