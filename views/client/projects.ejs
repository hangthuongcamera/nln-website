<%- include('partials/header') %>

<div class="container mx-auto px-4 max-w-7xl mt-6 mb-12 min-h-[60vh]">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary transition-colors"><i class="fa-solid fa-house mr-1"></i> Trang Chủ</a> <i class="fa-solid fa-angle-right mx-2 text-xs"></i>
        <span class="text-gray-800 font-medium">Dự Án Công Trình</span>
    </nav>

    <div class="text-center mb-10">
        <h1 class="text-2xl md:text-3xl font-bold text-primary mb-3 uppercase">Dự Án Tiêu Biểu</h1>
        <p class="text-gray-600 max-w-2xl mx-auto">Tự hào là đơn vị cung cấp vật tư thiết bị điện, nước, kim khí cho hàng trăm công trình lớn nhỏ trên toàn quốc.</p>
    </div>

    <!-- Phân loại / Danh mục dự án -->
    <div class="flex flex-wrap justify-center gap-2 md:gap-4 mb-10">
        <button onclick="filterProjects('all', this)" class="project-filter-btn px-5 py-2 rounded-full font-semibold text-sm md:text-base bg-primary text-white border border-transparent transition shadow-md">Tất cả dự án</button>
        <button onclick="filterProjects('dan-dung', this)" class="project-filter-btn px-5 py-2 rounded-full font-semibold text-sm md:text-base bg-white text-gray-600 border border-gray-200 hover:border-primary hover:text-primary transition shadow-sm">Dân dụng & Căn hộ</button>
        <button onclick="filterProjects('cong-nghiep', this)" class="project-filter-btn px-5 py-2 rounded-full font-semibold text-sm md:text-base bg-white text-gray-600 border border-gray-200 hover:border-primary hover:text-primary transition shadow-sm">Công nghiệp & Nhà máy</button>
        <button onclick="filterProjects('nghi-duong', this)" class="project-filter-btn px-5 py-2 rounded-full font-semibold text-sm md:text-base bg-white text-gray-600 border border-gray-200 hover:border-primary hover:text-primary transition shadow-sm">Nghỉ dưỡng & Resort</button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% if (projects && projects.length > 0) { %>
            <% projects.forEach(project => { %>
                <div class="project-card bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl transition-shadow duration-300 group animate-fade-in" data-category="<%= project.categorySlug || 'khac' %>">
                    <a href="/du-an/<%= project.slug %>" class="block relative aspect-[4/3] overflow-hidden">
                        <img src="<%= project.thumbnail || '/img/default-thumbnail.jpg' %>" alt="<%= project.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex items-end p-5">
                            <h3 class="text-white font-bold text-lg line-clamp-2 leading-tight">Dự án: <%= project.name %></h3>
                        </div>
                    </a>
                    <div class="p-5 flex flex-col h-full">
                        <div class="flex items-center gap-2 text-sm text-gray-500 mb-3">
                            <i class="fa-solid fa-location-dot text-secondary"></i> <%= project.location || 'Đang cập nhật' %>
                        </div>
                        <p class="text-sm text-gray-600 line-clamp-3 mb-5"><%= project.description %></p>
                        <a href="/du-an/<%= project.slug %>" class="mt-auto text-primary font-bold text-sm hover:text-secondary transition-colors flex items-center gap-1">Xem chi tiết dự án <i class="fa-solid fa-arrow-right-long text-xs"></i></a>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-full text-center py-10 bg-white rounded-lg border border-gray-100">
                <p class="text-gray-500">Hiện tại chưa có dữ liệu dự án công trình nào.</p>
            </div>
        <% } %>
    </div>
</div>

<script>
    function filterProjects(category, btnElement) {
        const buttons = document.querySelectorAll('.project-filter-btn');
        const activeClasses = ['bg-primary', 'text-white', 'border-transparent', 'shadow-md'];
        const inactiveClasses = ['bg-white', 'text-gray-600', 'border-gray-200', 'hover:border-primary', 'hover:text-primary', 'shadow-sm'];
        buttons.forEach(btn => { btn.classList.remove(...activeClasses); btn.classList.add(...inactiveClasses); });
        btnElement.classList.remove(...inactiveClasses); btnElement.classList.add(...activeClasses);

        const cards = document.querySelectorAll('.project-card');
        cards.forEach(card => { card.style.display = (category === 'all' || card.dataset.category === category) ? 'block' : 'none'; });
    }
</script>

<%- include('partials/footer') %>