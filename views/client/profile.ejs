<%- include('partials/header') %>

<div class="container mx-auto px-4 max-w-7xl mt-6 mb-12 min-h-[60vh]">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary transition-colors"><i class="fa-solid fa-house mr-1"></i> Trang Chủ</a> <i class="fa-solid fa-angle-right mx-2 text-xs"></i>
        <span class="text-gray-800 font-medium">Tài khoản của tôi</span>
    </nav>

    <div class="flex flex-col md:flex-row gap-6">
        <!-- Sidebar Profile -->
        <aside class="w-full md:w-1/4">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-6 text-center border-b border-gray-100 bg-gray-50">
                    <div id="profile-avatar" class="w-20 h-20 bg-primary text-white rounded-full flex items-center justify-center text-3xl font-bold mx-auto mb-3 shadow-inner"><i class="fa-solid fa-user"></i></div>
                    <h2 id="profile-name-display" class="font-bold text-gray-800">Đang tải...</h2>
                    <p id="profile-role-display" class="text-sm text-gray-500">Khách hàng thành viên</p>
                </div>
                <div class="flex flex-col p-2">
                    <button id="tab-link-info" onclick="switchProfileTab('info')" class="profile-tab-link text-left px-4 py-2.5 rounded font-medium bg-primary text-white transition"><i class="fa-regular fa-user mr-2 w-5"></i> Thông tin cá nhân</button>
                    <button id="tab-link-orders" onclick="switchProfileTab('orders')" class="profile-tab-link text-left px-4 py-2.5 rounded font-medium text-gray-700 hover:bg-gray-50 transition"><i class="fa-solid fa-box mr-2 w-5"></i> Lịch sử đơn hàng</button>
                    <button id="tab-link-quotes" onclick="switchProfileTab('quotes')" class="profile-tab-link text-left px-4 py-2.5 rounded font-medium text-gray-700 hover:bg-gray-50 transition"><i class="fa-solid fa-file-invoice mr-2 w-5"></i> Yêu cầu báo giá</button>
                    <button onclick="logoutUser()" class="text-left px-4 py-2.5 rounded font-medium text-red-600 hover:bg-red-50 transition mt-2 border-t border-gray-100"><i class="fa-solid fa-arrow-right-from-bracket mr-2 w-5"></i> Đăng xuất</button>
                </div>
            </div>
        </aside>

        <!-- Main Content Profile -->
        <div class="w-full md:w-3/4">
            <!-- Tab: Info -->
            <div id="profile-info" class="profile-tab-content bg-white p-6 rounded-xl shadow-sm border border-gray-100 block animate-fade-in">
                <h2 class="text-xl font-bold text-gray-800 mb-6 border-l-4 border-primary pl-3">Thông Tin Cá Nhân</h2>
                
                <div id="profile-update-success" class="hidden mb-4 bg-green-50 text-green-700 p-3 rounded-lg border border-green-200 text-sm">Cập nhật thông tin thành công!</div>
                <div id="profile-update-error" class="hidden mb-4 bg-red-50 text-red-700 p-3 rounded-lg border border-red-200 text-sm">Đã có lỗi xảy ra.</div>
                
                <form id="profile-update-form">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Họ và tên</label>
                            <input type="text" id="input-name" class="w-full px-4 py-2 border border-gray-300 rounded outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại</label>
                            <input type="tel" id="input-phone" class="w-full px-4 py-2 border border-gray-300 rounded outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Email (Tài khoản đăng nhập)</label>
                            <input type="email" id="input-email" class="w-full px-4 py-2 border border-gray-300 rounded outline-none bg-gray-50 text-sm text-gray-500 cursor-not-allowed" readonly disabled>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Ngày sinh</label>
                            <input type="date" id="input-dob" class="w-full px-4 py-2 border border-gray-300 rounded outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm">
                        </div>
                    </div>
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Địa chỉ mặc định giao hàng</label>
                        <input type="text" id="input-address" class="w-full px-4 py-2 border border-gray-300 rounded outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm" placeholder="Số nhà, Tên đường, Phường/Xã...">
                    </div>
                    <button type="submit" id="btn-update-profile" class="bg-primary text-white font-bold py-2.5 px-6 rounded hover:bg-blue-800 transition shadow-md shadow-blue-200 flex items-center justify-center">
                        <span id="btn-update-text">Lưu Thông Tin</span>
                        <i id="btn-update-spinner" class="fa-solid fa-spinner fa-spin ml-2 hidden"></i>
                    </button>
                </form>
            </div>

            <!-- Tab: Orders -->
            <div id="profile-orders" class="profile-tab-content bg-white p-6 rounded-xl shadow-sm border border-gray-100 hidden">
                <!-- Nội dung sẽ được render bằng JavaScript (Fetch API) -->
            </div>

            <!-- Tab: Quotes -->
            <div id="profile-quotes" class="profile-tab-content bg-white p-6 rounded-xl shadow-sm border border-gray-100 hidden">
                <h2 class="text-xl font-bold text-gray-800 mb-6 border-l-4 border-primary pl-3">Yêu Cầu Báo Giá B2B</h2>
                <div class="text-center py-10 text-gray-500">
                    <i class="fa-solid fa-file-invoice text-4xl mb-3 text-gray-300"></i>
                    <p>Bạn chưa gửi yêu cầu báo giá sỉ nào.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', async function() {
        const token = localStorage.getItem('token');
        if (!token) { window.location.href = '/'; return; } // Chưa đăng nhập thì đuổi ra Trang chủ

        try {
            // Lấy thông tin user qua API
            const response = await fetch('/api/v1/auth/me', { headers: { 'Authorization': `Bearer ${token}` } });
            if (response.ok) {
                const resData = await response.json();
                const user = resData.data || resData;
                
                document.getElementById('profile-name-display').innerText = user.name;
                if(user.name) document.getElementById('profile-avatar').innerHTML = user.name.charAt(0).toUpperCase();
                
                document.getElementById('input-name').value = user.name || '';
                document.getElementById('input-phone').value = user.phone || '';
                document.getElementById('input-email').value = user.email || '';
                document.getElementById('input-dob').value = user.dob ? user.dob.split('T')[0] : '';
                document.getElementById('input-address').value = user.address?.street || '';

                // Gọi hàm lấy lịch sử đơn hàng sau khi đã xác thực user thành công
                loadMyOrders(token);
            } else { localStorage.removeItem('token'); window.location.href = '/'; }
        } catch (error) { localStorage.removeItem('token'); window.location.href = '/'; }
    });

    // Gọi API cập nhật thông tin
    document.getElementById('profile-update-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        const btn = document.getElementById('btn-update-profile'), btnText = document.getElementById('btn-update-text'), spinner = document.getElementById('btn-update-spinner');
        const name = document.getElementById('input-name').value, phone = document.getElementById('input-phone').value;
        const dob = document.getElementById('input-dob').value, addressStr = document.getElementById('input-address').value;
        const token = localStorage.getItem('token');

        btn.disabled = true; btnText.innerText = 'Đang lưu...'; spinner.classList.remove('hidden');
        try {
            const response = await fetch('/api/v1/auth/profile', { method: 'PUT', headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` }, body: JSON.stringify({ name, phone, dob, address: { street: addressStr } }) });
            const data = await response.json();
            if (response.ok) {
                showToast('Cập nhật thông tin thành công!', 'success');
                document.getElementById('profile-name-display').innerText = name;
                if(name) document.getElementById('profile-avatar').innerHTML = name.charAt(0).toUpperCase();
            } else { showToast(data.message || 'Cập nhật thất bại!', 'error'); }
        } catch (error) { showToast('Lỗi kết nối máy chủ!', 'error'); } 
        finally { btn.disabled = false; btnText.innerText = 'Lưu Thông Tin'; spinner.classList.add('hidden'); }
    });

    // Hàm fetch và render lịch sử đơn hàng từ Backend
    async function loadMyOrders(token) {
        const ordersContainer = document.getElementById('profile-orders');
        try {
            ordersContainer.innerHTML = '<div class="text-center py-10"><i class="fa-solid fa-spinner fa-spin text-3xl text-primary"></i><p class="mt-3 text-gray-500">Đang tải lịch sử đơn hàng...</p></div>';
            
            const response = await fetch('/api/v1/orders/my-orders', {
                headers: { 'Authorization': `Bearer ${token}` }
            });

            if (response.ok) {
                const resData = await response.json();
                const orders = resData.data || [];

                if (orders.length === 0) {
                    ordersContainer.innerHTML = `
                        <h2 class="text-xl font-bold text-gray-800 mb-6 border-l-4 border-primary pl-3">Lịch Sử Đơn Hàng</h2>
                        <div class="text-center py-10 text-gray-500">
                            <i class="fa-solid fa-box-open text-4xl mb-3 text-gray-300"></i>
                            <p>Bạn chưa có đơn hàng nào.</p>
                            <a href="/category" class="inline-block mt-4 text-primary hover:text-secondary font-medium">Mua sắm ngay</a>
                        </div>
                    `;
                    return;
                }

                let tableHTML = `
                    <h2 class="text-xl font-bold text-gray-800 mb-6 border-l-4 border-primary pl-3">Lịch Sử Đơn Hàng</h2>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-[600px]">
                            <thead>
                                <tr class="bg-gray-50 text-gray-600 text-sm border-b border-gray-200">
                                    <th class="p-3 font-semibold">Mã đơn</th>
                                    <th class="p-3 font-semibold">Ngày mua</th>
                                    <th class="p-3 font-semibold">Sản phẩm</th>
                                    <th class="p-3 font-semibold">Tổng tiền</th>
                                    <th class="p-3 font-semibold">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm">
                `;

                orders.forEach(order => {
                    const date = new Date(order.createdAt).toLocaleDateString('vi-VN');
                    const total = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(order.totalAmount || 0);
                    
                    let productName = 'Đơn hàng';
                    if (order.items && order.items.length > 0) {
                        productName = order.items[0].name || 'Sản phẩm';
                        if (order.items.length > 1) productName += ` và ${order.items.length - 1} sản phẩm khác`;
                    }

                    let statusBadge = '';
                    switch(order.status) {
                        case 'pending': statusBadge = '<span class="bg-yellow-100 text-yellow-700 px-2.5 py-1 rounded text-xs font-semibold border border-yellow-200">Chờ duyệt</span>'; break;
                        case 'processing': statusBadge = '<span class="bg-blue-100 text-blue-700 px-2.5 py-1 rounded text-xs font-semibold border border-blue-200">Đang xử lý</span>'; break;
                        case 'shipping': statusBadge = '<span class="bg-indigo-100 text-indigo-700 px-2.5 py-1 rounded text-xs font-semibold border border-indigo-200">Đang giao</span>'; break;
                        case 'completed': statusBadge = '<span class="bg-green-100 text-green-700 px-2.5 py-1 rounded text-xs font-semibold border border-green-200">Hoàn thành</span>'; break;
                        case 'cancelled': statusBadge = '<span class="bg-gray-100 text-gray-600 px-2.5 py-1 rounded text-xs font-semibold border border-gray-200">Đã hủy</span>'; break;
                        default: statusBadge = `<span class="bg-gray-100 text-gray-600 px-2.5 py-1 rounded text-xs font-semibold border border-gray-200">${order.status || 'Khởi tạo'}</span>`;
                    }

                    tableHTML += `
                        <tr class="border-b border-gray-100 hover:bg-gray-50 transition cursor-pointer" onclick="window.location.href='/order/${order._id}'">
                            <td class="p-3 font-mono text-primary font-bold">${order.orderCode}</td>
                            <td class="p-3 text-gray-600">${date}</td>
                            <td class="p-3 text-gray-800 line-clamp-1 mt-1" title="${productName}">${productName}</td>
                            <td class="p-3 font-bold text-red-600">${total}</td>
                            <td class="p-3">${statusBadge}</td>
                        </tr>
                    `;
                });

                tableHTML += `</tbody></table></div>`;
                ordersContainer.innerHTML = tableHTML;
            } else { throw new Error('Lỗi fetch dữ liệu'); }
        } catch (error) {
            console.error('Lỗi khi tải đơn hàng:', error);
            ordersContainer.innerHTML = '<h2 class="text-xl font-bold text-gray-800 mb-6 border-l-4 border-primary pl-3">Lịch Sử Đơn Hàng</h2><div class="text-center py-10 text-red-500">Không thể tải danh sách đơn hàng lúc này. Vui lòng thử lại sau.</div>';
        }
    }

    function logoutUser() {
        localStorage.removeItem('token');
        window.location.href = '/';
    }

    function switchProfileTab(tabId) {
        document.querySelectorAll('.profile-tab-content').forEach(el => { el.classList.add('hidden'); el.classList.remove('block', 'animate-fade-in'); });
        document.getElementById('profile-' + tabId).classList.remove('hidden'); document.getElementById('profile-' + tabId).classList.add('block', 'animate-fade-in');
        document.querySelectorAll('.profile-tab-link').forEach(el => { el.classList.remove('bg-primary', 'text-white'); el.classList.add('text-gray-700', 'hover:bg-gray-50'); });
        document.getElementById('tab-link-' + tabId).classList.remove('text-gray-700', 'hover:bg-gray-50'); document.getElementById('tab-link-' + tabId).classList.add('bg-primary', 'text-white');
    }
</script>

<%- include('partials/footer') %>