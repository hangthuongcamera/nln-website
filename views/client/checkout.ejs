<%- include('partials/header') %>

<div class="container mx-auto px-4 max-w-7xl mt-6 mb-12 min-h-[60vh]">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary transition-colors"><i class="fa-solid fa-house mr-1"></i> Trang Chủ</a> <i class="fa-solid fa-angle-right mx-2 text-xs"></i>
        <a href="/cart" class="hover:text-primary transition-colors">Giỏ Hàng</a> <i class="fa-solid fa-angle-right mx-2 text-xs"></i>
        <span class="text-gray-800 font-medium">Thanh Toán</span>
    </nav>

    <h1 class="text-2xl font-bold text-gray-800 mb-6 border-l-4 border-primary pl-3">Thanh Toán Đơn Hàng</h1>

    <div class="flex flex-col lg:flex-row gap-8">
        <!-- Left: Billing Info -->
        <div class="w-full lg:w-2/3">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
                <h2 class="text-lg font-bold text-gray-800 mb-4 border-b pb-2"><i class="fa-regular fa-address-card mr-2 text-primary"></i>Thông tin giao hàng</h2>
                <form id="checkout-form">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Họ và tên <span class="text-red-500">*</span></label>
                            <input type="text" id="checkout-name" class="w-full px-3 py-2 border border-gray-300 rounded outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại <span class="text-red-500">*</span></label>
                            <input type="tel" id="checkout-phone" class="w-full px-3 py-2 border border-gray-300 rounded outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm" required>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                        <input type="email" id="checkout-email" class="w-full px-3 py-2 border border-gray-300 rounded outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm">
                    </div>
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Địa chỉ giao hàng <span class="text-red-500">*</span></label>
                        <input type="text" id="checkout-address" class="w-full px-3 py-2 border border-gray-300 rounded outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm mb-3" placeholder="Số nhà, Tên đường, Quận/Huyện, Tỉnh/Thành phố..." required>
                    </div>
                    <div class="mb-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Ghi chú đơn hàng (Tùy chọn)</label>
                        <textarea id="checkout-note" class="w-full px-3 py-2 border border-gray-300 rounded outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm" rows="3" placeholder="Ghi chú về giao hàng..."></textarea>
                    </div>
                </form>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h2 class="text-lg font-bold text-gray-800 mb-4 border-b pb-2"><i class="fa-regular fa-credit-card mr-2 text-primary"></i>Phương thức thanh toán</h2>
                <div class="space-y-3">
                    <label class="flex items-center gap-3 p-3 border border-primary bg-blue-50 rounded cursor-pointer relative">
                        <input type="radio" name="payment_method" value="COD" checked class="w-4 h-4 text-primary focus:ring-primary accent-primary">
                        <span class="font-medium text-gray-800">Thanh toán tiền mặt khi nhận hàng (COD)</span>
                    </label>
                    <label class="flex items-center gap-3 p-3 border border-gray-200 hover:border-primary hover:bg-blue-50 rounded cursor-pointer transition">
                        <input type="radio" name="payment_method" value="BANK_TRANSFER" class="w-4 h-4 text-primary focus:ring-primary accent-primary">
                        <span class="font-medium text-gray-800">Chuyển khoản qua ngân hàng</span>
                    </label>
                </div>
            </div>
        </div>

        <!-- Right: Order Summary for Checkout -->
        <div class="w-full lg:w-1/3">
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 sticky top-28">
                <h2 class="text-lg font-bold text-gray-800 mb-4 border-b border-gray-300 pb-3">Đơn hàng của bạn</h2>
                
                <div id="checkout-items" class="space-y-3 mb-4 border-b border-gray-300 pb-4">
                    <!-- Render by JS -->
                </div>
                
                <div class="space-y-2 mb-4 border-b border-gray-300 pb-4 text-sm">
                    <div class="flex justify-between text-gray-600">
                        <span>Tạm tính:</span>
                        <span id="checkout-subtotal" class="font-semibold text-gray-800">0đ</span>
                    </div>
                    <div class="flex justify-between text-gray-600">
                        <span>Phí vận chuyển:</span>
                        <span class="font-semibold text-gray-800">Liên hệ sau</span>
                    </div>
                </div>
                
                <div class="flex justify-between items-end mb-6">
                    <span class="font-bold text-gray-800">Tổng cộng:</span>
                    <span id="checkout-total" class="text-2xl font-bold text-red-600">0đ</span>
                </div>

                <button onclick="submitOrder()" id="btn-submit-order" class="w-full bg-secondary text-white font-bold py-3 rounded hover:bg-orange-600 transition shadow-lg shadow-orange-200 text-lg flex items-center justify-center">
                    <span id="btn-submit-text">ĐẶT HÀNG</span>
                    <i id="btn-submit-spinner" class="fa-solid fa-spinner fa-spin ml-2 hidden"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', async function() {
        const cart = JSON.parse(localStorage.getItem('cart')) || [];
        if (cart.length === 0) { window.location.href = '/cart'; return; }

        // Tải thông tin người dùng nếu đã đăng nhập
        const token = localStorage.getItem('token');
        if (token) {
            try {
                const response = await fetch('/api/v1/auth/me', { headers: { 'Authorization': `Bearer ${token}` } });
                if (response.ok) {
                    const user = (await response.json()).data;
                    document.getElementById('checkout-name').value = user.name || '';
                    document.getElementById('checkout-phone').value = user.phone || '';
                    document.getElementById('checkout-email').value = user.email || '';
                }
            } catch (e) {}
        }

        // Render đơn hàng
        const itemsContainer = document.getElementById('checkout-items');
        let subtotal = 0;
        cart.forEach(item => {
            const itemTotal = item.price * item.quantity;
            subtotal += itemTotal;
            itemsContainer.innerHTML += `<div class="flex justify-between text-sm items-center"><div class="flex items-center gap-2 pr-4"><span class="font-bold text-gray-700">${item.quantity}x</span><span class="text-gray-600 line-clamp-1">${item.name}</span></div><span class="font-semibold text-gray-800 shrink-0">${itemTotal.toLocaleString('vi-VN')}đ</span></div>`;
        });
        document.getElementById('checkout-subtotal').innerText = subtotal.toLocaleString('vi-VN') + 'đ';
        document.getElementById('checkout-total').innerText = subtotal.toLocaleString('vi-VN') + 'đ';
    });

    async function submitOrder() {
        const form = document.getElementById('checkout-form');
        if (!form.checkValidity()) { form.reportValidity(); return; }
        const btn = document.getElementById('btn-submit-order'), text = document.getElementById('btn-submit-text'), spinner = document.getElementById('btn-submit-spinner');
        btn.disabled = true; text.innerText = 'ĐANG XỬ LÝ...'; spinner.classList.remove('hidden');
        const cart = JSON.parse(localStorage.getItem('cart')) || [];
        
        let subTotal = 0;
        cart.forEach(item => subTotal += (item.price * item.quantity));
        const shippingFee = 0; // Có thể cập nhật logic tính phí ship sau
        const totalAmount = subTotal + shippingFee;

        const payload = {
            items: cart.map(item => ({ 
                product: item.productId || item.id, 
                variantId: item.variantId || '',
                variantName: item.variantName || '',
                name: item.name || 'Sản phẩm', 
                sku: item.sku || 'Đang cập nhật', 
                price: item.price || 0, 
                quantity: item.quantity || 1, 
                image: item.image || '' 
            })),
            customerName: document.getElementById('checkout-name').value,
            customerPhone: document.getElementById('checkout-phone').value,
            customerEmail: document.getElementById('checkout-email').value,
            shippingAddress: document.getElementById('checkout-address').value,
            subTotal: subTotal,
            shippingFee: shippingFee,
            discount: 0,
            totalAmount: totalAmount,
            paymentMethod: document.querySelector('input[name="payment_method"]:checked').value.toLowerCase(),
            note: document.getElementById('checkout-note').value
        };
        try {
            const token = localStorage.getItem('token');
            const headers = { 'Content-Type': 'application/json' };
            if (token) headers['Authorization'] = `Bearer ${token}`;
            const response = await fetch('/api/v1/orders', { method: 'POST', headers, body: JSON.stringify(payload) });
            const data = await response.json();
            if (response.ok) {
                localStorage.removeItem('cart'); if(typeof updateCartCounter === 'function') updateCartCounter();
                alert('🎉 Đặt hàng thành công! Mã đơn hàng của bạn là: ' + data.data.orderCode);
                window.location.href = token ? '/tai-khoan' : '/';
            } else { alert(data.message || 'Lỗi khi đặt hàng'); }
        } catch (error) { alert('Lỗi kết nối máy chủ'); } 
        finally { btn.disabled = false; text.innerText = 'ĐẶT HÀNG'; spinner.classList.add('hidden'); }
    }
</script>
<%- include('partials/footer') %>