    <!-- ==================== JAVASCRIPT LOGIC ==================== -->
    <script>
        // 1. Chuyển đổi View (Đã điều chỉnh cho kiến trúc MPA Node.js)
        function switchView(viewName) {
            const routes = {
                'home': '/',
                'about': '/about',
                'category': '/category',
                'product-detail': '/product-detail', // Route tạm, sẽ code Backend sau
                'cart': '/cart',
                'checkout': '/checkout',
                'blog-list': '/blogs',
                'blog-detail': '/blog-detail',
                'profile': '/profile',
                'contact': '/contact',
                'project-list': '/projects',
                'project-detail': '/project-detail'
            };
            if(routes[viewName]) {
                window.location.href = routes[viewName];
            } else {
                console.log('Chưa cấu hình route cho:', viewName);
                alert('Tính năng đang được phát triển!');
            }
        }

        function goToCategory(categoryName, parentCategory) {
            // Tạm thời redirect về trang /category
            window.location.href = '/category';
        }

        // Mở / Đóng Modal Đăng nhập / Đăng ký
        function openAuthModal(type) {
            const modal = document.getElementById('auth-modal');
            const modalContent = document.getElementById('auth-modal-content');
            const loginForm = document.getElementById('modal-login-form');
            const registerForm = document.getElementById('modal-register-form');

            modal.classList.remove('hidden');
            void modal.offsetWidth; 
            modal.classList.remove('opacity-0');
            modalContent.classList.remove('scale-95');
            modalContent.classList.add('scale-100');

            if (type === 'login') {
                loginForm.classList.remove('hidden');
                registerForm.classList.add('hidden');
            } else if (type === 'register') {
                registerForm.classList.remove('hidden');
                loginForm.classList.add('hidden');
            }
        }

        function closeAuthModal() {
            const modal = document.getElementById('auth-modal');
            const modalContent = document.getElementById('auth-modal-content');
            modal.classList.add('opacity-0');
            modalContent.classList.remove('scale-100');
            modalContent.classList.add('scale-95');
            setTimeout(() => { modal.classList.add('hidden'); }, 300); 
        }

        // Logic Chat & Quote
        function toggleChat() {
            const chatBox = document.getElementById('chat-box');
            if(chatBox) {
                if (chatBox.classList.contains('hidden')) {
                    chatBox.classList.remove('hidden'); chatBox.classList.add('flex');
                } else {
                    chatBox.classList.add('hidden'); chatBox.classList.remove('flex');
                }
            }
        }
        function requestQuote(productName) { alert(`Đã chuyển sản phẩm [${productName}] vào danh sách yêu cầu báo giá sỉ. Nhân viên sẽ liên hệ bạn sớm nhất!`); }
        function toggleAccordion(ulId, headerElement) {
            const ulElement = document.getElementById(ulId);
            const icon = headerElement.querySelector('i');
            if(ulElement && icon) {
                if (ulElement.classList.contains('hidden')) {
                    ulElement.classList.remove('hidden'); icon.style.transform = 'rotate(180deg)';
                } else {
                    ulElement.classList.add('hidden'); icon.style.transform = 'rotate(0deg)';
                }
            }
        }

        // Banner Carousel Logic
        let currentSlide = 0;
        const totalSlides = 3;
        function updateSlide() {
            const slidesContainer = document.getElementById('carousel-slides');
            if(slidesContainer) {
                slidesContainer.style.transform = `translateX(-${currentSlide * 100}%)`;
                const indicators = document.querySelectorAll('.indicator-btn');
                indicators.forEach((btn, index) => {
                    if (index === currentSlide) { btn.classList.replace('opacity-50', 'opacity-100'); } 
                    else { btn.classList.replace('opacity-100', 'opacity-50'); }
                });
            }
        }
        function nextSlide() { currentSlide = (currentSlide + 1) % totalSlides; updateSlide(); }
        function prevSlide() { currentSlide = (currentSlide - 1 + totalSlides) % totalSlides; updateSlide(); }
        function goToSlide(index) { currentSlide = index; updateSlide(); }
        setInterval(nextSlide, 5000);

        // Sliders Logic (Flash Sale & New Products)
        function scrollFlashSale(direction) {
            const container = document.getElementById('flash-sale-container');
            if (!container) return;
            const scrollAmount = (container.querySelector('div').offsetWidth + 16) * 2; 
            container.scrollLeft += direction * scrollAmount;
        }
        function scrollNewProducts(direction) {
            const container = document.getElementById('new-products-container');
            if (!container) return;
            const scrollAmount = container.clientWidth; 
            container.scrollLeft += direction * scrollAmount;
        }

        // Live Search Logic
        const demoProducts = [
            { id: 'CV-4.0', name: 'Dây cáp điện Cadivi CV 4.0 mm2 - Hàng chính hãng', price: '12,500đ', image: 'https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&fit=crop&q=80&w=100' },
            { id: 'CV-1.5', name: 'Dây cáp điện Cadivi CV 1.5 mm2', price: '5,500đ', image: 'https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&fit=crop&q=80&w=100' },
            { id: 'BM-PVC-27', name: 'Ống nhựa PVC Bình Minh Phi 27 (Dày 1.8mm)', price: '35,000đ', image: 'https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?auto=format&fit=crop&q=80&w=100' },
            { id: 'TL-KD-01', name: 'Kìm điện đa năng bọc cách điện 1000V Tolsen', price: '125,000đ', image: 'https://images.unsplash.com/photo-1504148455328-c376907d081c?auto=format&fit=crop&q=80&w=100' }
        ];

        const searchInput = document.getElementById('search-input');
        const searchSuggestions = document.getElementById('search-suggestions');

        if (searchInput && searchSuggestions) {
            searchInput.addEventListener('input', function(e) {
                const query = e.target.value.toLowerCase().trim();
                searchSuggestions.innerHTML = '';
                if (query.length < 2) { searchSuggestions.classList.add('hidden'); return; }
                const filtered = demoProducts.filter(p => p.name.toLowerCase().includes(query) || p.id.toLowerCase().includes(query));
                searchSuggestions.classList.remove('hidden');
                if (filtered.length > 0) {
                    const ul = document.createElement('ul');
                    filtered.forEach(p => {
                        const li = document.createElement('li');
                        li.className = 'border-b last:border-b-0 hover:bg-gray-50 transition-colors';
                        li.innerHTML = `<a href="#" onclick="switchView('product-detail'); document.getElementById('search-suggestions').classList.add('hidden');" class="flex items-center p-3 gap-3"><img src="${p.image}" class="w-10 h-10 object-cover rounded border border-gray-200"><div class="flex-1"><h4 class="text-sm font-semibold text-gray-800 line-clamp-1">${p.name}</h4><p class="text-xs text-gray-500 font-mono">SKU: ${p.id}</p></div><div class="text-red-600 font-bold text-sm">${p.price}</div></a>`;
                        ul.appendChild(li);
                    });
                    searchSuggestions.appendChild(ul);
                } else {
                    searchSuggestions.innerHTML = `<div class="p-6 text-center text-sm text-gray-500">Không tìm thấy sản phẩm nào phù hợp với "<b>${query}</b>".</div>`;
                }
            });

            document.addEventListener('click', function(e) {
                if (!searchInput.contains(e.target) && !searchSuggestions.contains(e.target)) {
                    searchSuggestions.classList.add('hidden');
                }
            });
        }

        // Hiệu ứng Typewriter cho Search
        const placeholderTexts = ['Bạn cần tìm gì...?', 'Tìm kiếm sản phẩm ...', 'Nhập tên sản phẩm...'];
        let placeholderTextIndex = 0; let placeholderCharIndex = 0; let isDeletingPlaceholder = false;
        function typeWriterEffect() {
            if (!searchInput) return;
            const currentText = placeholderTexts[placeholderTextIndex];
            if (isDeletingPlaceholder) { searchInput.setAttribute('placeholder', currentText.substring(0, placeholderCharIndex - 1)); placeholderCharIndex--; } 
            else { searchInput.setAttribute('placeholder', currentText.substring(0, placeholderCharIndex + 1)); placeholderCharIndex++; }
            
            let typeSpeed = isDeletingPlaceholder ? 50 : 100;
            if (!isDeletingPlaceholder && placeholderCharIndex === currentText.length) { typeSpeed = 1500; isDeletingPlaceholder = true; } 
            else if (isDeletingPlaceholder && placeholderCharIndex === 0) { isDeletingPlaceholder = false; placeholderTextIndex = (placeholderTextIndex + 1) % placeholderTexts.length; typeSpeed = 500; }
            setTimeout(typeWriterEffect, typeSpeed);
        }
        setTimeout(typeWriterEffect, 1000);

        // Back to top button logic
        window.addEventListener('scroll', function() {
            const backToTopBtn = document.getElementById('back-to-top');
            if(backToTopBtn) {
                if (window.scrollY > 300) { backToTopBtn.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none'); backToTopBtn.classList.add('opacity-100', 'translate-y-0'); } 
                else { backToTopBtn.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none'); backToTopBtn.classList.remove('opacity-100', 'translate-y-0'); }
            }
        });

        // Xử lý sự kiện click để cuộn mượt lên đầu trang
        document.addEventListener('click', function(e) {
            const backToTopBtn = e.target.closest('#back-to-top');
            if (backToTopBtn) {
                e.preventDefault();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        });
    </script>