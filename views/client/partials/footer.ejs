                        <li><a href="#" class="hover:text-white transition"><i class="fa-solid fa-angle-right mr-2 text-xs"></i>Chính sách bảo hành</a></li>
                        <li><a href="#" class="hover:text-white transition"><i class="fa-solid fa-angle-right mr-2 text-xs"></i>Chính sách đổi trả</a></li>
                        <li><a href="#" class="hover:text-white transition"><i class="fa-solid fa-angle-right mr-2 text-xs"></i>Phương thức thanh toán</a></li>
                        <li><a href="#" class="hover:text-white transition"><i class="fa-solid fa-angle-right mr-2 text-xs"></i>Chính sách giao hàng</a></li>
                        <li><a href="#" class="hover:text-white transition"><i class="fa-solid fa-angle-right mr-2 text-xs"></i>Báo giá dành cho đại lý</a></li>
