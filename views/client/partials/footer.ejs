                            <li class="flex items-start"><i class="fa-solid fa-phone mt-1 mr-3 text-secondary"></i> Hotline sỉ: <a href="tel:<%= setting.contact.phone %>" class="hover:text-white"><%= setting.contact.phone %></a></li>
                            <li class="flex items-start"><i class="fa-solid fa-envelope mt-1 mr-3 text-secondary"></i> <a href="mailto:<%= setting.contact.email %>" class="hover:text-white"><%= setting.contact.email %></a></li>
                        <% } else { %>
                            <li class="flex items-start"><i class="fa-solid fa-location-dot mt-1 mr-3 text-secondary"></i> 485 Đ.Đồng Khởi, P.Tam Hiệp, Đồng Nai</li>
                            <li class="flex items-start"><i class="fa-solid fa-phone mt-1 mr-3 text-secondary"></i> Hotline sỉ: 0938.117.848</li>
                            <li class="flex items-start"><i class="fa-solid fa-envelope mt-1 mr-3 text-secondary"></i> nhatlinhnhi@gmail.com</li>
                        <% } %>
