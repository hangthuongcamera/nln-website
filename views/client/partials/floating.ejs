    <!-- ==================== AUTH MODALS (LOGIN / REGISTER) ==================== -->
    <div id="auth-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/60 backdrop-blur-sm transition-opacity opacity-0 duration-300" onclick="if(event.target === this) closeAuthModal()">
        <div class="relative w-full max-w-md bg-white p-8 rounded-xl shadow-2xl border border-gray-100 transform scale-95 transition-transform duration-300" id="auth-modal-content">
            <!-- Nút đóng -->
            <button onclick="closeAuthModal()" class="absolute top-4 right-4 text-gray-400 hover:text-red-500 transition text-xl"><i class="fa-solid fa-xmark"></i></button>

            <!-- Form Đăng Nhập -->
            <div id="modal-login-form">
                <h2 class="text-2xl font-bold text-primary text-center mb-2">Đăng Nhập Tài Khoản</h2>
                <p class="text-center text-gray-500 text-sm mb-8">Chào mừng bạn quay trở lại!</p>
                <form onsubmit="event.preventDefault(); alert('Đăng nhập thành công (demo)!'); closeAuthModal(); switchView('profile');">
                    <div class="mb-4">
                        <label for="login-email" class="block text-sm font-medium text-gray-700 mb-1">Email hoặc Số điện thoại</label>
                        <input type="text" id="login-email" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg outline-none focus:border-primary focus:ring-1 focus:ring-primary" placeholder="vidu@email.com" required>
                    </div>
                    <div class="mb-6">
                        <label for="login-password" class="block text-sm font-medium text-gray-700 mb-1">Mật khẩu</label>
                        <input type="password" id="login-password" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg outline-none focus:border-primary focus:ring-1 focus:ring-primary" placeholder="••••••••" required>
                    </div>
                    <div class="flex justify-between items-center mb-6 text-sm">
                        <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" class="w-4 h-4 rounded text-primary focus:ring-primary"> Ghi nhớ đăng nhập</label>
                        <a href="#" class="font-medium text-primary hover:text-secondary">Quên mật khẩu?</a>
                    </div>
                    <button type="submit" class="w-full bg-primary text-white font-bold py-3 rounded-lg hover:bg-blue-800 transition shadow-lg shadow-blue-200">ĐĂNG NHẬP</button>
                </form>
                
                <!-- Social Login -->
                <div class="mt-6">
                    <div class="relative">
                        <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-300"></div></div>
                        <div class="relative flex justify-center text-sm"><span class="px-2 bg-white text-gray-500">Hoặc đăng nhập bằng</span></div>
                    </div>
                    <div class="mt-6 grid grid-cols-2 gap-3">
                        <button type="button" onclick="alert('Tính năng đăng nhập bằng Google (Demo)')" class="w-full inline-flex justify-center items-center py-2.5 px-4 border border-gray-300 rounded-lg shadow-sm bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition"><i class="fa-brands fa-google text-red-500 mr-2 text-lg"></i> Google</button>
                        <button type="button" onclick="alert('Tính năng đăng nhập bằng Facebook (Demo)')" class="w-full inline-flex justify-center items-center py-2.5 px-4 border border-gray-300 rounded-lg shadow-sm bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition"><i class="fa-brands fa-facebook text-blue-600 mr-2 text-lg"></i> Facebook</button>
                    </div>
                </div>
                <p class="text-center text-sm text-gray-600 mt-6">Chưa có tài khoản? <a href="#" onclick="openAuthModal('register')" class="font-bold text-secondary hover:underline">Đăng ký ngay</a></p>
            </div>

            <!-- Form Đăng Ký -->
            <div id="modal-register-form" class="hidden">
                <h2 class="text-2xl font-bold text-primary text-center mb-2">Tạo Tài Khoản Mới</h2>
                <p class="text-center text-gray-500 text-sm mb-8">Nhận nhiều ưu đãi hơn khi là thành viên!</p>
                <form onsubmit="event.preventDefault(); alert('Đăng ký thành công (demo)!'); openAuthModal('login');">
                    <div class="mb-4">
                        <label for="reg-name" class="block text-sm font-medium text-gray-700 mb-1">Họ và Tên</label>
                        <input type="text" id="reg-name" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg outline-none focus:border-primary focus:ring-1 focus:ring-primary" placeholder="Nguyễn Văn A" required>
                    </div>
                    <div class="mb-4">
                        <label for="reg-phone" class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại</label>
                        <input type="tel" id="reg-phone" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg outline-none focus:border-primary focus:ring-1 focus:ring-primary" placeholder="0909123456" required>
                    </div>
                    <div class="mb-4">
                        <label for="reg-password" class="block text-sm font-medium text-gray-700 mb-1">Mật khẩu</label>
                        <input type="password" id="reg-password" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg outline-none focus:border-primary focus:ring-1 focus:ring-primary" placeholder="Tối thiểu 6 ký tự" required>
                    </div>
                    <button type="submit" class="w-full bg-secondary text-white font-bold py-3 rounded-lg hover:bg-orange-600 transition shadow-lg shadow-orange-200 mt-2">TẠO TÀI KHOẢN</button>
                </form>
                <p class="text-center text-sm text-gray-600 mt-8">Đã có tài khoản? <a href="#" onclick="openAuthModal('login')" class="font-bold text-primary hover:underline">Đăng nhập ngay</a></p>
            </div>
        </div>
    </div>

    <!-- ==================== FLOATING CHAT WIDGET ==================== -->
    <div class="fixed bottom-6 right-6 flex flex-col items-end gap-3 z-50">
        <a href="tel:0909123456" class="w-12 h-12 bg-green-500 text-white rounded-full flex items-center justify-center shadow-lg hover:bg-green-600 transition-transform hover:scale-110"><i class="fa-solid fa-phone-volume text-xl animate-pulse"></i></a>
        <div id="chat-box" class="bg-white w-72 rounded-lg shadow-2xl border border-gray-200 hidden flex-col overflow-hidden origin-bottom-right transition-all">
            <div class="bg-primary text-white p-3 font-bold flex justify-between items-center"><span>Tư vấn trực tuyến</span><i class="fa-solid fa-xmark cursor-pointer hover:text-red-300" onclick="toggleChat()"></i></div>
            <div class="h-48 p-3 bg-gray-50 overflow-y-auto text-sm flex flex-col gap-2"><div class="bg-blue-100 text-blue-900 p-2 rounded-lg rounded-tl-none self-start max-w-[85%]">Chào bạn, Nhất Linh Nhi có thể giúp gì cho bạn hôm nay? Bạn cần báo giá vật tư nào ạ?</div></div>
            <div class="p-2 border-t flex"><input type="text" placeholder="Nhập tin nhắn..." class="flex-1 text-sm outline-none px-2"><button class="text-primary hover:text-secondary"><i class="fa-solid fa-paper-plane"></i></button></div>
        </div>
        <button onclick="toggleChat()" class="w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center shadow-2xl hover:bg-blue-800 transition duration-300 transform hover:-translate-y-1 relative group focus:outline-none">
            <span class="absolute top-0 right-0 w-3 h-3 bg-red-500 border-2 border-white rounded-full animate-pulse"></span><i class="far fa-comment-dots text-2xl"></i><span class="absolute right-16 bg-gray-900 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition whitespace-nowrap">Chat hỗ trợ / Báo giá</span>
        </button>
    </div>

    <!-- Nút Cuộn Lên Đầu Trang -->
    <button id="back-to-top" onclick="window.scrollTo({ top: 0, behavior: 'smooth' })" class="fixed bottom-40 right-6 w-12 h-12 bg-gray-800 text-white rounded-full flex items-center justify-center shadow-lg hover:bg-gray-700 transition-all opacity-0 translate-y-10 z-40 pointer-events-none">
        <i class="fa-solid fa-arrow-up"></i>
    </button>