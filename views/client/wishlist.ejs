<%- include('partials/head', { title: pageTitle, seoDescription: seoDescription }) %>
<%- include('partials/header') %>

<main class="container mx-auto px-4 max-w-7xl my-8 md:my-12">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
        <h1 class="text-2xl md:text-3xl font-bold text-primary mb-6 border-b pb-4">
            <i class="fa-regular fa-heart mr-3 text-red-500"></i>Danh Sách Yêu Thích
        </h1>

        <% if (user && wishlistProducts && wishlistProducts.length > 0) { %>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
                <% wishlistProducts.forEach(product => { %>
                    <%- include('partials/_product-card', { product: product }) %>
                <% }) %>
            </div>
        <% } else if (user && wishlistProducts && wishlistProducts.length === 0) { %>
            <div class="text-center py-12">
                <i class="fa-regular fa-heart text-6xl text-gray-300 mb-4"></i>
                <p class="text-xl font-semibold text-gray-700 mb-2">Danh sách yêu thích của bạn đang trống.</p>
                <p class="text-gray-500 mb-6">Hãy thêm những sản phẩm bạn yêu thích vào đây để dễ dàng theo dõi nhé!</p>
                <a href="/category" class="bg-primary text-white px-6 py-3 rounded-lg hover:bg-blue-800 transition font-medium">
                    <i class="fa-solid fa-shop mr-2"></i> Tiếp tục mua sắm
                </a>
            </div>
        <% } else { %>
            <div class="text-center py-12">
                <i class="fa-solid fa-user-lock text-6xl text-gray-300 mb-4"></i>
                <p class="text-xl font-semibold text-gray-700 mb-2">Bạn cần đăng nhập để xem danh sách yêu thích.</p>
                <p class="text-gray-500 mb-6">Đăng nhập hoặc đăng ký tài khoản để lưu lại những sản phẩm bạn quan tâm.</p>
                <button onclick="openAuthModal('login')" class="bg-primary text-white px-6 py-3 rounded-lg hover:bg-blue-800 transition font-medium">
                    <i class="fa-solid fa-right-to-bracket mr-2"></i> Đăng nhập ngay
                </button>
            </div>
        <% } %>
    </div>
</main>

<%- include('partials/footer') %>