<%- include('partials/header') %>

<div class="container mx-auto px-4 max-w-7xl mt-6 mb-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary transition-colors"><i class="fa-solid fa-house mr-1"></i> Trang Chủ</a> <i class="fa-solid fa-angle-right mx-2 text-xs"></i>
        <span class="text-gray-800 font-medium">Liên Hệ</span>
    </nav>
    
    <h1 class="text-2xl md:text-3xl font-bold text-gray-800 mb-6 border-l-4 border-primary pl-3">Liên Hệ Với Nhất Linh Nhi</h1>

    <div class="flex flex-col lg:flex-row gap-8 mb-8">
        <!-- Box Thông tin -->
        <div class="w-full lg:w-1/3 bg-white p-6 md:p-8 rounded-xl shadow-sm border border-gray-100">
            <h2 class="text-lg font-bold text-primary mb-6 uppercase border-b pb-2">Thông tin liên hệ</h2>
            <ul class="space-y-5 text-gray-600 text-sm md:text-base">
                <li class="flex items-start"><i class="fa-solid fa-location-dot mt-1 mr-4 text-secondary text-xl"></i> <div><strong class="text-gray-800">Trụ sở chính:</strong><br>485 Đ.Đồng Khởi, P.Tam Hiệp, Biên Hòa, Đồng Nai</div></li>
                <li class="flex items-start"><i class="fa-solid fa-phone mt-1 mr-4 text-secondary text-xl"></i> <div><strong class="text-gray-800">Hotline mua sỉ & lẻ:</strong><br><a href="tel:0938117848" class="hover:text-primary transition-colors">0938.117.848</a></div></li>
                <li class="flex items-start"><i class="fa-solid fa-envelope mt-1 mr-4 text-secondary text-xl"></i> <div><strong class="text-gray-800">Email phản hồi:</strong><br><a href="mailto:info@nhatlinhnhi.com" class="hover:text-primary transition-colors">info@nhatlinhnhi.com</a></div></li>
                <li class="flex items-start"><i class="fa-solid fa-clock mt-1 mr-4 text-secondary text-xl"></i> <div><strong class="text-gray-800">Giờ làm việc:</strong><br>Thứ 2 - Thứ 7: 7h30 - 17h00<br>Chủ nhật: Nghỉ</div></li>
            </ul>
        </div>
        
        <!-- Box Form Gửi tin nhắn -->
        <div class="w-full lg:w-2/3 bg-white p-6 md:p-8 rounded-xl shadow-sm border border-gray-100">
            <h2 class="text-lg font-bold text-primary mb-6 uppercase border-b pb-2">Gửi tin nhắn cho chúng tôi</h2>
            
            <!-- Cảnh báo trạng thái gửi form -->
            <div id="contact-success" class="hidden mb-4 bg-green-50 text-green-700 p-4 rounded-lg border border-green-200">
                <i class="fa-solid fa-circle-check mr-2"></i> Cảm ơn bạn! Tin nhắn của bạn đã được gửi thành công. Chúng tôi sẽ phản hồi sớm nhất.
            </div>
            <div id="contact-error" class="hidden mb-4 bg-red-50 text-red-700 p-4 rounded-lg border border-red-200">
                <i class="fa-solid fa-circle-xmark mr-2"></i> Đã có lỗi xảy ra khi gửi tin nhắn. Vui lòng thử lại sau!
            </div>

            <form id="contactForm" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Họ và tên <span class="text-red-500">*</span></label>
                        <input type="text" name="name" placeholder="Nhập tên của bạn" class="w-full px-4 py-2 border border-gray-300 rounded outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm" required>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại <span class="text-red-500">*</span></label>
                        <input type="tel" name="phone" placeholder="Nhập số điện thoại" class="w-full px-4 py-2 border border-gray-300 rounded outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm" required>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input type="email" name="email" placeholder="Email nhận phản hồi" class="w-full px-4 py-2 border border-gray-300 rounded outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nội dung lời nhắn <span class="text-red-500">*</span></label>
                    <textarea rows="5" name="message" placeholder="Bạn cần tư vấn sản phẩm, chính sách đại lý hay khiếu nại dịch vụ..." class="w-full px-4 py-2 border border-gray-300 rounded outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm" required></textarea>
                </div>
                <button type="submit" id="submitBtn" class="bg-secondary text-white font-bold py-3 px-8 rounded hover:bg-orange-600 transition shadow-lg shadow-orange-200 flex items-center justify-center disabled:opacity-50 disabled:cursor-wait">
                    <span id="btnText">GỬI TIN NHẮN</span>
                    <i id="btnSpinner" class="fa-solid fa-spinner fa-spin ml-2 hidden"></i>
                </button>
            </form>
        </div>
    </div>
    
    <!-- Google Maps Iframe -->
    <div class="w-full h-96 bg-gray-200 rounded-xl overflow-hidden shadow-sm border border-gray-200">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d791.2747467619213!2d106.85459105522426!3d10.966039538820876!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3174dd8e34cdb90b%3A0x1e4c0bb456eb7563!2sC%C3%B4ng%20ty%20TNHH%20Nh%E1%BA%A5t%20Linh%20Nhi!5e1!3m2!1svi!2s!4v1778227998539!5m2!1svi!2s" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
</div>

<script>
    document.getElementById('contactForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const submitBtn = document.getElementById('submitBtn');
        const btnText = document.getElementById('btnText');
        const btnSpinner = document.getElementById('btnSpinner');
        const successMsg = document.getElementById('contact-success');
        const errorMsg = document.getElementById('contact-error');
        
        // Chuẩn bị dữ liệu
        const formData = {
            name: this.name.value, phone: this.phone.value, email: this.email.value, message: this.message.value
        };

        // Hiệu ứng Loading
        submitBtn.disabled = true; btnText.innerText = 'ĐANG GỬI...'; btnSpinner.classList.remove('hidden');
        successMsg.classList.add('hidden'); errorMsg.classList.add('hidden');

        try {
            const response = await fetch('/api/v1/contacts', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(formData) });
            if (response.ok) { successMsg.classList.remove('hidden'); this.reset(); } 
            else { errorMsg.classList.remove('hidden'); }
        } catch (error) { errorMsg.classList.remove('hidden'); } 
        finally { submitBtn.disabled = false; btnText.innerText = 'GỬI TIN NHẮN'; btnSpinner.classList.add('hidden'); }
    });
</script>

<%- include('partials/footer') %>