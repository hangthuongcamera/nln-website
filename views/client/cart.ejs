<%- include('partials/header') %>

<div class="container mx-auto px-4 max-w-7xl mt-6 mb-12 min-h-[60vh]">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary transition-colors"><i class="fa-solid fa-house mr-1"></i> Trang Chủ</a> <i class="fa-solid fa-angle-right mx-2 text-xs"></i>
        <span class="text-gray-800 font-medium">Giỏ Hàng</span>
    </nav>

    <h1 class="text-2xl md:text-3xl font-bold text-gray-800 mb-8 border-l-4 border-primary pl-3">Giỏ Hàng Của Bạn</h1>

    <!-- Loading / Empty State -->
    <div id="cart-empty" class="hidden text-center py-16 bg-white rounded-xl border border-gray-100 shadow-sm">
        <i class="fa-solid fa-cart-arrow-down text-6xl text-gray-300 mb-4"></i>
        <h2 class="text-xl font-bold text-gray-700 mb-2">Giỏ hàng đang trống</h2>
        <p class="text-gray-500 mb-6">Chưa có sản phẩm nào trong giỏ hàng của bạn.</p>
        <a href="/category" class="inline-block bg-primary text-white font-bold py-2.5 px-6 rounded hover:bg-blue-800 transition shadow-md">Tiếp tục mua sắm</a>
    </div>

    <div id="cart-content" class="hidden flex-col lg:flex-row gap-8">
        <!-- Danh sách sản phẩm -->
        <div class="w-full lg:w-2/3 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="hidden md:grid grid-cols-12 gap-4 p-4 bg-gray-50 border-b border-gray-200 text-sm font-bold text-gray-600">
                <div class="col-span-6">Sản phẩm</div>
                <div class="col-span-2 text-center">Đơn giá</div>
                <div class="col-span-2 text-center">Số lượng</div>
                <div class="col-span-2 text-right">Thành tiền</div>
            </div>
            
            <div id="cart-items-container" class="divide-y divide-gray-100">
                <!-- Render bằng JS -->
            </div>
        </div>

        <!-- Tóm tắt đơn hàng -->
        <div class="w-full lg:w-1/3">
            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 sticky top-24">
                <h2 class="text-lg font-bold text-gray-800 mb-4 pb-2 border-b">Tóm tắt đơn hàng</h2>
                <div class="flex justify-between items-center mb-3 text-gray-600">
                    <span>Tạm tính (<span id="summary-count">0</span> SP):</span>
                    <span id="summary-subtotal" class="font-semibold text-gray-800">0đ</span>
                </div>
                <div class="flex justify-between items-center mb-4 text-gray-600">
                    <span>Phí vận chuyển:</span>
                    <span class="text-sm italic">Thỏa thuận sau</span>
                </div>
                <div class="border-t border-gray-100 pt-4 mb-6 flex justify-between items-center">
                    <span class="font-bold text-gray-800">Tổng tiền:</span>
                    <span id="summary-total" class="text-xl font-bold text-red-600">0đ</span>
                </div>
                <a href="/checkout" class="block w-full bg-secondary text-white text-center font-bold py-3 rounded hover:bg-orange-600 transition shadow-lg shadow-orange-200 mb-3">TIẾN HÀNH ĐẶT HÀNG</a>
                <a href="/category" class="block w-full text-center text-primary font-medium hover:underline text-sm"><i class="fa-solid fa-arrow-left-long mr-1"></i> Mua thêm sản phẩm khác</a>
            </div>
        </div>
    </div>
</div>

<script>
    function renderCart() {
        let cart = [];
        try {
            cart = JSON.parse(localStorage.getItem('cart')) || [];
            if (!Array.isArray(cart)) cart = [];
        } catch(error) {
            cart = [];
        }
        const emptyDiv = document.getElementById('cart-empty');
        const contentDiv = document.getElementById('cart-content');
        const container = document.getElementById('cart-items-container');
        
        if (cart.length === 0) {
            emptyDiv.classList.remove('hidden'); contentDiv.classList.add('hidden');
            return;
        }
        
        emptyDiv.classList.add('hidden'); contentDiv.classList.remove('hidden'); contentDiv.classList.add('flex');
        container.innerHTML = '';
        let subtotal = 0; let totalItems = 0;

        cart.forEach((item, index) => {
            const price = Number(item.price) || 0;
            const quantity = Number(item.quantity) || 1;
            const itemTotal = price * quantity;
            subtotal += itemTotal; totalItems += quantity;
            
            container.innerHTML += `
                <div class="p-4 flex flex-col md:grid md:grid-cols-12 gap-4 items-center group relative">
                    <div class="col-span-6 flex items-center gap-4 w-full">
                        <img src="${item.image || '/img/placeholder.png'}" alt="${item.name}" class="w-20 h-20 object-cover rounded border border-gray-200 flex-shrink-0">
                        <div>
                            <a href="/product/${item.productId || item.id}" class="font-bold text-gray-800 hover:text-primary line-clamp-2 leading-tight">${item.name || 'Sản phẩm'}</a>
                            <p class="text-xs text-gray-500 mt-1">SKU: ${item.sku || 'N/A'}</p>
                        </div>
                    </div>
                    <div class="col-span-2 text-center text-gray-600 w-full md:w-auto flex justify-between md:block"><span class="md:hidden font-medium">Đơn giá:</span> ${price.toLocaleString('vi-VN')}đ</div>
                    <div class="col-span-2 flex justify-center w-full md:w-auto">
                        <div class="flex items-center border border-gray-300 rounded overflow-hidden">
                            <button type="button" onclick="updateQuantity(${index}, -1)" class="w-8 h-8 flex items-center justify-center bg-gray-50 hover:bg-gray-200 transition text-gray-600"><i class="fa-solid fa-minus text-xs"></i></button>
                            <input type="text" value="${quantity}" class="w-10 h-8 text-center text-sm font-medium border-x border-gray-300 outline-none pointer-events-none" readonly>
                            <button type="button" onclick="updateQuantity(${index}, 1)" class="w-8 h-8 flex items-center justify-center bg-gray-50 hover:bg-gray-200 transition text-gray-600"><i class="fa-solid fa-plus text-xs"></i></button>
                        </div>
                    </div>
                    <div class="col-span-2 text-right font-bold text-primary w-full md:w-auto flex justify-between md:block"><span class="md:hidden text-gray-600">Thành tiền:</span> ${itemTotal.toLocaleString('vi-VN')}đ</div>
                    <button type="button" onclick="removeItem(${index})" class="absolute md:relative top-2 right-2 md:top-auto md:right-auto text-gray-400 hover:text-red-500 transition px-2"><i class="fa-solid fa-trash-can"></i></button>
                </div>
            `;
        });

        document.getElementById('summary-count').innerText = totalItems;
        document.getElementById('summary-subtotal').innerText = subtotal.toLocaleString('vi-VN') + 'đ';
        document.getElementById('summary-total').innerText = subtotal.toLocaleString('vi-VN') + 'đ';
    }

    function updateQuantity(index, change) {
        let cart = [];
        try {
            cart = JSON.parse(localStorage.getItem('cart')) || [];
            if (!Array.isArray(cart)) cart = [];
        } catch(error) {
            cart = [];
        }
        if (cart[index].quantity + change > 0) { 
            cart[index].quantity += change; 
            localStorage.setItem('cart', JSON.stringify(cart)); 
            renderCart(); 
            if (typeof updateCartCounter === 'function') updateCartCounter(); 
        }
    }
    
    function removeItem(index) { 
        let cart = [];
        try {
            cart = JSON.parse(localStorage.getItem('cart')) || [];
            if (!Array.isArray(cart)) cart = [];
        } catch(error) {
            cart = [];
        }
        cart.splice(index, 1); 
        localStorage.setItem('cart', JSON.stringify(cart)); 
        renderCart(); 
        if (typeof updateCartCounter === 'function') updateCartCounter(); 
    }
    document.addEventListener('DOMContentLoaded', renderCart);
</script>

<%- include('partials/footer') %>