<%- include('partials/head', { title: 'Quản lý Liên hệ - Admin Nhất Linh Nhi' }) %>

<div class="flex h-screen w-full">
    <div id="admin-toast-container" class="fixed top-20 right-6 z-50 flex flex-col gap-3 overflow-x-hidden p-2 pointer-events-none"></div>
    <%- include('partials/sidebar') %>

    <div class="flex-1 flex flex-col min-w-0 bg-gray-50">
        <%- include('partials/topbar', { pageTitle: 'Tin Nhắn Liên Hệ' }) %>

        <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8">
            <div class="admin-page block animate-fade-in">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-800">Tin Nhắn Liên Hệ</h2>
                        <p class="text-gray-500 text-sm mt-1">Quản lý và phản hồi tin nhắn, góp ý từ khách hàng.</p>
                    </div>
                </div>

                <!-- Bộ lọc -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6 flex flex-col md:flex-row gap-4">
                    <div class="relative flex-1">
                        <input type="text" placeholder="Tìm kiếm theo tên, email, sđt..." class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg outline-none focus:border-primary text-sm">
                        <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    </div>
                    <select class="border border-gray-300 rounded-lg px-3 py-2.5 outline-none focus:border-primary text-sm text-gray-700 min-w-[150px]">
                        <option value="">Tất cả trạng thái</option>
                        <option value="unread">Chưa đọc</option>
                        <option value="read">Đã đọc / Đã xử lý</option>
                    </select>
                </div>

                <!-- Bảng danh sách -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-[800px]">
                            <thead>
                                <tr class="bg-gray-50 text-gray-600 text-sm border-b border-gray-200">
                                    <th class="p-4 font-semibold w-12 text-center"><input type="checkbox" class="rounded text-primary focus:ring-primary"></th>
                                    <th class="p-4 font-semibold">Khách hàng</th>
                                    <th class="p-4 font-semibold">Nội dung lời nhắn</th>
                                    <th class="p-4 font-semibold">Ngày gửi</th>
                                    <th class="p-4 font-semibold text-center">Trạng thái</th>
                                    <th class="p-4 font-semibold text-right">Hành động</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm divide-y divide-gray-100">
                                <!-- Message 1 (Chưa đọc) -->
                                <tr class="hover:bg-gray-50 transition cursor-pointer bg-blue-50/30" onclick="openContactModal('KH01')">
                                    <td class="p-4 text-center" onclick="event.stopPropagation()"><input type="checkbox" class="rounded text-primary focus:ring-primary"></td>
                                    <td class="p-4">
                                        <p class="font-bold text-gray-800">Lê Đại Hành</p>
                                        <p class="text-xs text-gray-500">0933.xxx.xxx - lehanh@email.com</p>
                                    </td>
                                    <td class="p-4">
                                        <p class="text-gray-800 font-medium line-clamp-1">Hỏi về chính sách đại lý tỉnh</p>
                                        <p class="text-xs text-gray-500 mt-0.5 line-clamp-1">Tôi ở Lâm Đồng muốn mở đại lý thiết bị điện, cần xin bảng giá...</p>
                                    </td>
                                    <td class="p-4 text-gray-600">Hôm nay, 09:30</td>
                                    <td class="p-4 text-center"><span class="bg-red-100 text-red-700 px-2.5 py-1 rounded-full text-xs font-bold">Chưa đọc</span></td>
                                    <td class="p-4 text-right" onclick="event.stopPropagation()">
                                        <button onclick="openContactModal('KH01')" class="text-blue-500 hover:text-blue-700 p-2"><i class="fa-solid fa-eye"></i></button>
                                        <button class="text-red-500 hover:text-red-700 p-2"><i class="fa-solid fa-trash-can"></i></button>
                                    </td>
                                </tr>
                                <!-- Message 2 (Đã đọc) -->
                                <tr class="hover:bg-gray-50 transition cursor-pointer" onclick="openContactModal('KH02')">
                                    <td class="p-4 text-center" onclick="event.stopPropagation()"><input type="checkbox" class="rounded text-primary focus:ring-primary"></td>
                                    <td class="p-4">
                                        <p class="font-bold text-gray-700">Trần Phương</p>
                                        <p class="text-xs text-gray-400">0988.xxx.xxx - phuongt@email.com</p>
                                    </td>
                                    <td class="p-4">
                                        <p class="text-gray-600 font-medium line-clamp-1">Khiếu nại giao hàng chậm</p>
                                        <p class="text-xs text-gray-400 mt-0.5 line-clamp-1">Mã đơn DH-0988 của tôi sao đến nay vẫn chưa giao tới nơi?</p>
                                    </td>
                                    <td class="p-4 text-gray-500">Hôm qua, 14:20</td>
                                    <td class="p-4 text-center"><span class="bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full text-xs font-semibold">Đã xử lý</span></td>
                                    <td class="p-4 text-right" onclick="event.stopPropagation()">
                                        <button onclick="openContactModal('KH02')" class="text-blue-500 hover:text-blue-700 p-2"><i class="fa-solid fa-eye"></i></button>
                                        <button class="text-red-500 hover:text-red-700 p-2"><i class="fa-solid fa-trash-can"></i></button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<!-- Modal Xem & Phản hồi -->
<div id="modal-contact" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/50 backdrop-blur-sm transition-opacity">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-2xl mx-4 overflow-hidden flex flex-col scale-95 transform transition-transform" id="modal-contact-content">
        <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
            <h3 class="font-bold text-gray-800 text-lg"><i class="fa-regular fa-envelope mr-2 text-primary"></i>Chi Tiết Lời Nhắn</h3>
            <button onclick="closeContactModal()" class="text-gray-400 hover:text-red-500 transition"><i class="fa-solid fa-xmark text-xl"></i></button>
        </div>
        <div class="p-6">
            <div class="bg-gray-50 p-4 rounded-lg border border-gray-200 mb-6 text-sm">
                <p class="mb-2"><strong class="w-24 inline-block text-gray-600">Người gửi:</strong> <span class="font-bold text-gray-800">Lê Đại Hành</span></p>
                <p class="mb-2"><strong class="w-24 inline-block text-gray-600">Liên hệ:</strong> 0933.xxx.xxx | lehanh@email.com</p>
                <div class="mt-4 pt-4 border-t border-gray-200 text-gray-700 italic">"Tôi ở Lâm Đồng muốn mở đại lý thiết bị điện, cần xin bảng giá và chính sách chiết khấu của công ty."</div>
            </div>
            <form onsubmit="event.preventDefault(); closeContactModal(); showAdminToast('Thành công', 'Đã lưu trạng thái xử lý', 'success');">
                <div class="mb-4"><label class="block text-sm font-medium text-gray-700 mb-1">Cập nhật trạng thái</label><select class="w-full px-3 py-2 border border-gray-300 rounded outline-none focus:border-primary text-sm"><option value="unread">Chưa xử lý</option><option value="read" selected>Đã liên hệ xử lý xong</option></select></div>
                <div class="mb-4"><label class="block text-sm font-medium text-gray-700 mb-1">Ghi chú nội bộ</label><textarea rows="3" class="w-full px-3 py-2 border border-gray-300 rounded outline-none focus:border-primary text-sm resize-none" placeholder="Đã gọi điện tư vấn và gửi email báo giá..."></textarea></div>
                <div class="flex justify-end gap-3 pt-2"><button type="button" onclick="closeContactModal()" class="bg-white border border-gray-300 text-gray-700 font-medium py-2 px-5 rounded hover:bg-gray-50 transition">Hủy</button><button type="submit" class="bg-primary text-white font-bold py-2 px-5 rounded hover:bg-blue-800 transition shadow">Lưu Trạng Thái</button></div>
            </form>
        </div>
    </div>
</div>

<%- include('partials/scripts') %>
<script>
    function openContactModal(id) { const modal = document.getElementById('modal-contact'); modal.classList.remove('hidden'); modal.classList.add('flex'); setTimeout(() => document.getElementById('modal-contact-content').classList.remove('scale-95'), 10); }
    function closeContactModal() { document.getElementById('modal-contact-content').classList.add('scale-95'); setTimeout(() => { document.getElementById('modal-contact').classList.add('hidden'); document.getElementById('modal-contact').classList.remove('flex'); }, 200); }
</script>