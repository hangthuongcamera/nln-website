<!-- Product Picker Modal -->
<div id="product-picker-modal" class="fixed inset-0 bg-gray-900 bg-opacity-50 flex items-center justify-center z-[70] hidden animate-fade-in-fast" onclick="closeProductPickerModal()">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-3xl transform transition-all duration-300 scale-95 flex flex-col max-h-[90vh]" onclick="event.stopPropagation()">
        <!-- Modal Header -->
        <div class="flex justify-between items-center p-4 border-b border-gray-200">
            <h3 class="text-lg font-bold text-gray-800 flex items-center gap-2">
                <i class="fa-solid fa-crosshairs text-primary"></i>
                Chọn Sản Phẩm để Ghim
            </h3>
            <button onclick="closeProductPickerModal()" class="text-gray-400 hover:text-gray-600 w-8 h-8 rounded-full flex items-center justify-center hover:bg-gray-100">
                <i class="fa-solid fa-times fa-lg"></i>
            </button>
        </div>

        <!-- Modal Body -->
        <div class="p-6 flex-1 flex flex-col min-h-0">
            <div class="relative mb-4">
                <input type="text" id="picker-search-input" placeholder="Tìm theo tên sản phẩm, SKU..." class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg outline-none focus:border-primary text-sm">
                <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400"></i>
            </div>
            <div id="picker-search-results" class="flex-1 overflow-y-auto border border-gray-200 rounded-lg bg-gray-50 p-2">
                <div class="text-center text-gray-500 p-8">Nhập từ khóa để tìm sản phẩm...</div>
            </div>
        </div>

        <!-- Modal Footer -->
        <div class="flex justify-end items-center p-4 bg-gray-50 border-t border-gray-200 rounded-b-xl">
            <button onclick="closeProductPickerModal()" class="bg-white border border-gray-300 text-gray-700 font-semibold py-2 px-4 rounded-lg hover:bg-gray-50 transition text-sm mr-2">Đóng</button>
        </div>
    </div>
</div>