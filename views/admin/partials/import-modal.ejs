<!-- Import Modal -->
<div id="import-modal" class="fixed inset-0 bg-gray-900 bg-opacity-50 flex items-center justify-center z-[60] hidden animate-fade-in-fast" onclick="closeImportModal()">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-2xl transform transition-all duration-300 scale-95" onclick="event.stopPropagation()">
        <!-- Modal Header -->
        <div class="flex justify-between items-center p-4 border-b border-gray-200">
            <h3 class="text-lg font-bold text-gray-800 flex items-center gap-2">
                <i class="fa-solid fa-file-import text-purple-600"></i>
                Nhập sản phẩm từ file Excel
            </h3>
            <button onclick="closeImportModal()" class="text-gray-400 hover:text-gray-600 w-8 h-8 rounded-full flex items-center justify-center hover:bg-gray-100">
                <i class="fa-solid fa-times fa-lg"></i>
            </button>
        </div>

        <!-- Modal Body -->
        <div class="p-6">
            <!-- Step 1: Upload -->
            <div id="import-step-1">
                <p class="text-sm text-gray-600 mb-4">
                    Để đảm bảo dữ liệu được xử lý chính xác, vui lòng sử dụng file mẫu của chúng tôi. Hệ thống sẽ tự động khớp các cột dữ liệu.
                </p>
                <a href="/templates/product_import_template.xlsx" download class="inline-flex items-center gap-2 bg-green-50 text-green-700 font-semibold py-2 px-4 rounded-lg hover:bg-green-100 transition text-sm mb-6">
                    <i class="fa-solid fa-file-excel"></i>
                    Tải về file Excel mẫu
                </a>

                <div id="drop-zone" class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center cursor-pointer hover:border-primary hover:bg-blue-50 transition">
                    <input type="file" id="file-input" class="hidden" accept=".xlsx, .xls">
                    <i class="fa-solid fa-cloud-arrow-up text-4xl text-gray-400 mb-3"></i>
                    <p class="text-gray-700 font-semibold">Kéo và thả file vào đây, hoặc <span class="text-primary">nhấn để chọn file</span></p>
                    <p class="text-xs text-gray-500 mt-1">Chỉ chấp nhận file .xlsx hoặc .xls</p>
                    <p id="file-name-display" class="mt-3 text-sm font-semibold text-green-600"></p>
                </div>
            </div>

            <!-- Step 2: Progress/Result -->
            <div id="import-step-2" class="hidden">
                <div class="flex items-center gap-3 mb-4">
                    <i class="fa-solid fa-spinner fa-spin text-primary text-2xl"></i>
                    <div>
                        <p class="font-semibold text-gray-800">Đang xử lý file...</p>
                        <p class="text-sm text-gray-500">Vui lòng không đóng cửa sổ này.</p>
                    </div>
                </div>
                <div id="import-result" class="mt-4 text-sm max-h-60 overflow-y-auto bg-gray-50 p-3 rounded-lg"></div>
            </div>
        </div>

        <!-- Modal Footer -->
        <div class="flex justify-end items-center p-4 bg-gray-50 border-t border-gray-200 rounded-b-xl">
            <button onclick="closeImportModal()" class="bg-white border border-gray-300 text-gray-700 font-semibold py-2 px-4 rounded-lg hover:bg-gray-50 transition text-sm mr-2">Hủy</button>
            <button id="start-import-btn" onclick="startImport()" class="bg-primary text-white font-bold py-2 px-4 rounded-lg hover:bg-blue-800 transition text-sm disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2" disabled>
                <i class="fa-solid fa-play"></i> Bắt đầu nhập
            </button>
        </div>
    </div>
</div>