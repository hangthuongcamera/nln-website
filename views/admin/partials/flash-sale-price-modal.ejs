<!-- Flash Sale Price Input Modal -->
<div id="flash-sale-price-modal" class="fixed inset-0 bg-gray-900 bg-opacity-50 flex items-center justify-center z-[80] hidden animate-fade-in-fast" onclick="closeFlashSalePriceModal()">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-sm transform transition-all duration-300 scale-95" onclick="event.stopPropagation()">
        <!-- Modal Header -->
        <div class="flex justify-between items-center p-4 border-b border-gray-200">
            <h3 class="text-lg font-bold text-gray-800 flex items-center gap-2">
                <i class="fa-solid fa-tag text-red-600"></i>
                Nhập Giá Flash Sale
            </h3>
            <button onclick="closeFlashSalePriceModal()" class="text-gray-400 hover:text-gray-600 w-8 h-8 rounded-full flex items-center justify-center hover:bg-gray-100">
                <i class="fa-solid fa-times fa-lg"></i>
            </button>
        </div>

        <!-- Modal Body -->
        <div class="p-6">
            <p class="text-sm text-gray-600 mb-4">Vui lòng nhập giá Flash Sale cho sản phẩm <span id="flash-sale-product-name" class="font-semibold text-primary"></span>.</p>
            <div class="mb-4">
                <label for="flash-sale-price-input" class="block text-sm font-bold text-gray-700 mb-2">Giá Flash Sale (VNĐ)</label>
                <input type="number" id="flash-sale-price-input" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg outline-none focus:border-primary text-sm" placeholder="Ví dụ: 99000" min="0">
            </div>
            <p class="text-xs text-gray-500">Giá hiện tại: <span id="flash-sale-current-price" class="font-semibold"></span></p>
            <p class="text-xs text-gray-500">Giá cũ: <span id="flash-sale-old-price" class="font-semibold"></span></p>
        </div>

        <!-- Modal Footer -->
        <div class="flex justify-end items-center p-4 bg-gray-50 border-t border-gray-200 rounded-b-xl">
            <button onclick="closeFlashSalePriceModal()" class="bg-white border border-gray-300 text-gray-700 font-semibold py-2 px-4 rounded-lg hover:bg-gray-50 transition text-sm mr-2">Hủy</button>
            <button id="confirm-flash-sale-price-btn" class="bg-primary text-white font-bold py-2 px-4 rounded-lg hover:bg-blue-800 transition text-sm flex items-center gap-2">
                <i class="fa-solid fa-check"></i> Xác nhận
            </button>
        </div>
    </div>
</div>