<%- include('partials/head', { title: 'Quản lý Khách hàng - Admin Nhất Linh Nhi' }) %>

<div class="flex h-screen w-full">
    <div id="admin-toast-container" class="fixed top-20 right-6 z-50 flex flex-col gap-3 overflow-x-hidden p-2 pointer-events-none"></div>
    <%- include('partials/sidebar') %>

    <div class="flex-1 flex flex-col min-w-0 bg-gray-50">
        <%- include('partials/topbar', { pageTitle: 'Trung tâm Khách hàng' }) %>

        <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8">
            <div class="admin-page block animate-fade-in">
                <!-- Header -->
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-800">Trung tâm Khách hàng</h2>
                        <p class="text-gray-500 text-sm mt-1">Quản lý thông tin khách hàng, lịch sử mua hàng và phân tích hành vi.</p>
                    </div>
                    <div class="flex flex-wrap items-center gap-2">
                        <button onclick="exportCustomers()" class="bg-white border border-green-200 text-green-700 font-semibold py-2.5 px-4 rounded-lg hover:bg-green-50 transition text-sm flex items-center gap-2">
                            <i class="fa-solid fa-file-export"></i> Xuất CSV
                        </button>
                        <button type="button" onclick="resetFilters()" class="bg-white border border-gray-200 text-gray-700 font-semibold py-2.5 px-4 rounded-lg hover:bg-gray-50 transition text-sm flex items-center gap-2">
                            <i class="fa-solid fa-rotate-left"></i> Xóa lọc
                        </button>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div id="customer-stats" class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
                    <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm">
                        <p class="text-xs text-gray-500">Tổng khách hàng</p>
                        <p class="text-2xl font-bold text-gray-800" data-stat="total">...</p>
                    </div>
                    <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm">
                        <p class="text-xs text-gray-500">Khách VIP</p>
                        <p class="text-2xl font-bold text-purple-600" data-stat="vip">...</p>
                    </div>
                    <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm">
                        <p class="text-xs text-gray-500">Khách thường xuyên</p>
                        <p class="text-2xl font-bold text-blue-600" data-stat="regular">...</p>
                    </div>
                    <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm">
                        <p class="text-xs text-gray-500">Khách mới</p>
                        <p class="text-2xl font-bold text-green-600" data-stat="new">...</p>
                    </div>
                </div>

                <!-- Filters -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
                        <div class="relative xl:col-span-2">
                            <input type="text" id="search-customer" placeholder="Tìm theo tên, SĐT, email..." class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg outline-none focus:border-primary text-sm">
                            <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400"></i>
                        </div>

                        <select id="filter-tier" class="border border-gray-300 rounded-lg px-3 py-2.5 outline-none focus:border-primary text-sm text-gray-700">
                            <option value="">Tất cả hạng</option>
                            <option value="vip">VIP</option>
                            <option value="regular">Thường xuyên</option>
                            <option value="new">Mới</option>
                        </select>

                        <select id="sort-customers" class="border border-gray-300 rounded-lg px-3 py-2.5 outline-none focus:border-primary text-sm text-gray-700">
                            <option value="newest">Mới nhất</option>
                            <option value="oldest">Cũ nhất</option>
                            <option value="orders_desc">Nhiều đơn nhất</option>
                            <option value="spent_desc">Chi tiêu cao nhất</option>
                        </select>

                        <select id="page-limit" class="border border-gray-300 rounded-lg px-3 py-2.5 outline-none focus:border-primary text-sm text-gray-700">
                            <option value="20">20 dòng/trang</option>
                            <option value="50">50 dòng/trang</option>
                            <option value="100">100 dòng/trang</option>
                        </select>

                        <button onclick="loadCustomers(1)" class="bg-blue-50 border border-blue-200 text-primary font-semibold py-2.5 px-4 rounded-lg hover:bg-blue-100 transition text-sm">
                            <i class="fa-solid fa-filter mr-1"></i> Áp dụng bộ lọc
                        </button>
                    </div>
                </div>

                <!-- Customers Table -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="p-4 border-b border-gray-100 flex flex-col md:flex-row justify-between items-start md:items-center gap-3 bg-white">
                        <div class="text-sm text-gray-600">
                            <span id="total-customers">0</span> khách hàng
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-[1000px]">
                            <thead>
                                <tr class="bg-gray-50 text-gray-600 text-sm border-b border-gray-200">
                                    <th class="p-4 font-semibold">Khách hàng</th>
                                    <th class="p-4 font-semibold text-center">Hạng</th>
                                    <th class="p-4 font-semibold text-center">Số đơn</th>
                                    <th class="p-4 font-semibold text-right">Tổng chi tiêu</th>
                                    <th class="p-4 font-semibold text-center">Đơn gần nhất</th>
                                    <th class="p-4 font-semibold text-right">Hành động</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm divide-y divide-gray-100" id="customers-tbody">
                                <tr><td colspan="6" class="p-8 text-center text-gray-500">Đang tải dữ liệu...</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="p-4 border-t border-gray-100 flex flex-col md:flex-row justify-between items-center gap-4 bg-gray-50">
                        <div class="text-sm text-gray-500" id="pagination-info">Hiển thị 0 khách hàng</div>
                        <div class="flex items-center gap-1 flex-wrap justify-center" id="pagination-controls"></div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<!-- Customer Detail Modal -->
<div id="customer-detail-modal" class="fixed inset-0 bg-gray-900 bg-opacity-50 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-4xl max-h-[90vh] overflow-hidden flex flex-col">
        <div class="flex items-center justify-between p-5 border-b border-gray-100 bg-gray-50">
            <h3 class="text-lg font-bold text-gray-800">Chi tiết khách hàng</h3>
            <button onclick="closeCustomerModal()" class="text-gray-400 hover:text-gray-600 transition">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>
        <div class="flex-1 overflow-y-auto p-5" id="modal-customer-content"></div>
        <div class="p-4 border-t border-gray-100 bg-gray-50 flex justify-end gap-3">
            <button onclick="closeCustomerModal()" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-100 transition text-sm">Đóng</button>
        </div>
    </div>
</div>

<%- include('partials/scripts') %>
<script>
    const token = localStorage.getItem('token');
    let currentPage = 1;
    let currentCustomerId = null;

    document.addEventListener('DOMContentLoaded', () => {
        if (!token) window.location.href = '/admin/login';
        loadCustomerStats();
        loadCustomers();

        document.getElementById('search-customer').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') loadCustomers(1);
        });

        ['filter-tier', 'sort-customers', 'page-limit'].forEach(id => {
            document.getElementById(id).addEventListener('change', () => loadCustomers(1));
        });
    });

    async function loadCustomerStats() {
        try {
            const res = await fetch('/api/v1/customers/stats', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const data = await res.json();
            if (data.success) {
                document.querySelector('[data-stat="total"]').textContent = data.data.total;
                document.querySelector('[data-stat="vip"]').textContent = data.data.vip;
                document.querySelector('[data-stat="regular"]').textContent = data.data.regular;
                document.querySelector('[data-stat="new"]').textContent = data.data.new;
            }
        } catch (err) { console.error('Lỗi load stats:', err); }
    }

    async function loadCustomers(page = 1) {
        currentPage = page;
        const params = new URLSearchParams({ 
            page, 
            limit: document.getElementById('page-limit').value,
            sort: document.getElementById('sort-customers').value
        });
        
        const tier = document.getElementById('filter-tier').value;
        const search = document.getElementById('search-customer').value;

        if (tier) params.append('tier', tier);
        if (search) params.append('search', search);

        try {
            const res = await fetch(`/api/v1/customers?${params}`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const data = await res.json();
            if (data.success) {
                renderCustomers(data.data);
                renderPagination(data.pagination);
                document.getElementById('total-customers').textContent = data.pagination.total;
            }
        } catch (err) { console.error('Lỗi load customers:', err); }
    }

    function renderCustomers(customers) {
        const tbody = document.getElementById('customers-tbody');
        if (!customers.length) {
            tbody.innerHTML = '<tr><td colspan="6" class="p-8 text-center text-gray-500">Không có khách hàng nào</td></tr>';
            return;
        }
        tbody.innerHTML = customers.map(customer => `
            <tr class="hover:bg-gray-50 transition">
                <td class="p-4">
                    <div class="font-medium">${customer.name || 'Khách vãng lai'}</div>
                    <div class="text-xs text-gray-500">${customer.phone || ''}</div>
                    ${customer.email ? `<div class="text-xs text-gray-400">${customer.email}</div>` : ''}
                </td>
                <td class="p-4 text-center">
                    <span class="px-3 py-1 rounded-full text-xs font-semibold ${getTierBadgeClass(customer.tier)}">
                        ${getTierLabel(customer.tier)}
                    </span>
                </td>
                <td class="p-4 text-center font-semibold">${customer.totalOrders || 0}</td>
                <td class="p-4 text-right font-semibold text-primary">${formatCurrency(customer.totalSpent || 0)}</td>
                <td class="p-4 text-center text-xs text-gray-500">${customer.lastOrderDate ? formatDate(customer.lastOrderDate) : '-'}</td>
                <td class="p-4 text-right">
                    <div class="flex items-center justify-end gap-2">
                        <button onclick="viewCustomerDetail('${customer._id}')" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition" title="Xem chi tiết">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                </td>
            </tr>
        `).join('');
    }

    function renderPagination(pagination) {
        const container = document.getElementById('pagination-controls');
        const info = document.getElementById('pagination-info');
        
        info.textContent = `Hiển thị ${pagination.page} / ${pagination.pages} trang (${pagination.total} khách hàng)`;
        
        if (pagination.pages <= 1) { container.innerHTML = ''; return; }

        let html = '';
        if (pagination.page > 1) html += `<button onclick="loadCustomers(${pagination.page - 1})" class="px-3 py-1 border rounded hover:bg-gray-100"><i class="fa-solid fa-chevron-left"></i></button>`;
        
        for (let i = 1; i <= pagination.pages; i++) {
            if (i === 1 || i === pagination.pages || (i >= pagination.page - 2 && i <= pagination.page + 2)) {
                html += `<button onclick="loadCustomers(${i})" class="px-3 py-1 border rounded ${i === pagination.page ? 'bg-primary text-white' : 'hover:bg-gray-100'}">${i}</button>`;
            } else if (i === pagination.page - 3 || i === pagination.page + 3) {
                html += `<span class="px-2">...</span>`;
            }
        }
        
        if (pagination.page < pagination.pages) html += `<button onclick="loadCustomers(${pagination.page + 1})" class="px-3 py-1 border rounded hover:bg-gray-100"><i class="fa-solid fa-chevron-right"></i></button>`;
        
        container.innerHTML = html;
    }

    async function viewCustomerDetail(id) {
        currentCustomerId = id;
        try {
            const res = await fetch(`/api/v1/customers/${id}`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const data = await res.json();
            if (data.success) {
                document.getElementById('modal-customer-content').innerHTML = renderCustomerDetail(data.data);
                document.getElementById('customer-detail-modal').classList.remove('hidden');
            }
        } catch (err) { showToast('Lỗi khi tải chi tiết khách hàng', 'error'); }
    }

    function renderCustomerDetail(customer) {
        return `
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <h4 class="font-semibold text-gray-800 mb-3">Thông tin cơ bản</h4>
                    <div class="bg-gray-50 rounded-lg p-4 space-y-2 text-sm">
                        <p><span class="text-gray-500">Tên:</span> <span class="font-medium">${customer.name || 'Khách vãng lai'}</span></p>
                        <p><span class="text-gray-500">SĐT:</span> ${customer.phone || '-'}</p>
                        <p><span class="text-gray-500">Email:</span> ${customer.email || '-'}</p>
                        <p><span class="text-gray-500">Địa chỉ:</span> ${customer.address || '-'}</p>
                        <p><span class="text-gray-500">Hạng:</span> <span class="px-2 py-0.5 rounded text-xs font-semibold ${getTierBadgeClass(customer.tier)}">${getTierLabel(customer.tier)}</span></p>
                    </div>
                </div>
                <div>
                    <h4 class="font-semibold text-gray-800 mb-3">Thống kê mua hàng</h4>
                    <div class="bg-gray-50 rounded-lg p-4 space-y-2 text-sm">
                        <p><span class="text-gray-500">Tổng đơn hàng:</span> <span class="font-semibold">${customer.totalOrders || 0}</span></p>
                        <p><span class="text-gray-500">Tổng chi tiêu:</span> <span class="font-semibold text-primary">${formatCurrency(customer.totalSpent || 0)}</span></p>
                        <p><span class="text-gray-500">Đơn trung bình:</span> <span class="font-semibold">${formatCurrency(customer.avgOrderValue || 0)}</span></p>
                        <p><span class="text-gray-500">Đơn gần nhất:</span> ${customer.lastOrderDate ? formatDate(customer.lastOrderDate) : '-'}</p>
                        <p><span class="text-gray-500">Ngày đăng ký:</span> ${formatDate(customer.createdAt)}</p>
                    </div>
                </div>
            </div>

            ${customer.recentOrders && customer.recentOrders.length > 0 ? `
                <div>
                    <h4 class="font-semibold text-gray-800 mb-3">Đơn hàng gần đây</h4>
                    <div class="border rounded-lg overflow-hidden">
                        <table class="w-full text-sm">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="p-3 text-left">Mã đơn</th>
                                    <th class="p-3 text-center">Ngày</th>
                                    <th class="p-3 text-right">Tổng tiền</th>
                                    <th class="p-3 text-center">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y">
                                ${customer.recentOrders.map(order => `
                                    <tr>
                                        <td class="p-3 font-medium text-primary">${order.orderCode}</td>
                                        <td class="p-3 text-center text-xs">${formatDate(order.createdAt)}</td>
                                        <td class="p-3 text-right font-semibold">${formatCurrency(order.totalAmount)}</td>
                                        <td class="p-3 text-center"><span class="px-2 py-0.5 rounded text-xs ${getOrderStatusClass(order.status)}">${getOrderStatusLabel(order.status)}</span></td>
                                    </tr>
                                `).join('')}
                            </tbody>
                        </table>
                    </div>
                </div>
            ` : '<p class="text-gray-500 text-center py-4">Chưa có đơn hàng nào</p>'}
        `;
    }

    function closeCustomerModal() {
        document.getElementById('customer-detail-modal').classList.add('hidden');
        currentCustomerId = null;
    }

    function resetFilters() {
        document.getElementById('search-customer').value = '';
        document.getElementById('filter-tier').value = '';
        document.getElementById('sort-customers').value = 'newest';
        loadCustomers(1);
    }

    function formatCurrency(amount) {
        return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount || 0);
    }

    function formatDate(date) {
        return new Date(date).toLocaleString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
    }

    function getTierBadgeClass(tier) {
        const classes = {
            vip: 'bg-purple-100 text-purple-700',
            regular: 'bg-blue-100 text-blue-700',
            new: 'bg-green-100 text-green-700'
        };
        return classes[tier] || 'bg-gray-100 text-gray-700';
    }

    function getTierLabel(tier) {
        const labels = {
            vip: 'VIP',
            regular: 'Thường xuyên',
            new: 'Mới'
        };
        return labels[tier] || 'Khách';
    }

    function getOrderStatusClass(status) {
        const classes = {
            pending: 'bg-yellow-100 text-yellow-700',
            processing: 'bg-blue-100 text-blue-700',
            shipping: 'bg-purple-100 text-purple-700',
            completed: 'bg-green-100 text-green-700',
            cancelled: 'bg-red-100 text-red-700'
        };
        return classes[status] || 'bg-gray-100 text-gray-700';
    }

    function getOrderStatusLabel(status) {
        const labels = {
            pending: 'Chờ xử lý',
            processing: 'Đang xử lý',
            shipping: 'Đang giao',
            completed: 'Hoàn thành',
            cancelled: 'Đã hủy'
        };
        return labels[status] || status;
    }

    function showToast(message, type = 'info') {
        const container = document.getElementById('admin-toast-container');
        const toast = document.createElement('div');
        const colors = { success: 'bg-green-500', error: 'bg-red-500', info: 'bg-blue-500' };
        toast.className = `${colors[type]} text-white px-4 py-3 rounded-lg shadow-lg flex items-center gap-2 animate-fade-in`;
        toast.innerHTML = `<i class="fa-solid fa-${type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle'}"></i>${message}`;
        container.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }
</script>