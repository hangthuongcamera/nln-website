<%- include('partials/head', { title: 'Quản lý Trang tĩnh - Admin Nhất Linh Nhi' }) %>

<div class="flex h-screen w-full">
    <div id="admin-toast-container" class="fixed top-20 right-6 z-50 flex flex-col gap-3 overflow-x-hidden p-2 pointer-events-none"></div>
    <%- include('partials/sidebar') %>

    <div class="flex-1 flex flex-col min-w-0 bg-gray-50">
        <%- include('partials/topbar', { pageTitle: 'Trang Tĩnh & Chính Sách' }) %>

        <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8">
            <div class="admin-page block animate-fade-in">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-800">Trang Tĩnh & Chính Sách</h2>
                        <p class="text-gray-500 text-sm mt-1">Quản lý nội dung các trang Giới thiệu, Chính sách đổi trả, Bảo hành...</p>
                    </div>
                    <button onclick="openPageModal()" class="bg-primary text-white font-bold py-2.5 px-5 rounded-lg hover:bg-blue-800 transition shadow-md flex items-center gap-2">
                        <i class="fa-solid fa-plus"></i> Thêm Trang Mới
                    </button>
                </div>

                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-[800px]">
                            <thead>
                                <tr class="bg-gray-50 text-gray-600 text-sm border-b border-gray-200">
                                    <th class="p-4 font-semibold">Tên trang hiển thị</th>
                                    <th class="p-4 font-semibold">Đường dẫn (Slug)</th>
                                    <th class="p-4 font-semibold">Cập nhật lần cuối</th>
                                    <th class="p-4 font-semibold text-center">Trạng thái</th>
                                    <th class="p-4 font-semibold text-right">Hành động</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm divide-y divide-gray-100">
                                <tr class="hover:bg-gray-50 transition">
                                    <td class="p-4 font-bold text-gray-800"><i class="fa-solid fa-building mr-2 text-primary"></i>Giới thiệu công ty</td>
                                    <td class="p-4 font-mono text-gray-500 text-xs bg-gray-100 px-2 py-1 rounded inline-block mt-3">/about</td>
                                    <td class="p-4 text-gray-600">10/05/2026</td>
                                    <td class="p-4 text-center"><span class="bg-green-100 text-green-700 px-2.5 py-1 rounded-full text-xs font-semibold">Hiển thị</span></td>
                                    <td class="p-4 text-right">
                                        <button onclick="openPageModal()" class="text-blue-500 hover:text-blue-700 p-2"><i class="fa-solid fa-pen-to-square"></i></button>
                                        <button class="text-gray-300 cursor-not-allowed p-2" title="Trang hệ thống không thể xóa"><i class="fa-solid fa-trash-can"></i></button>
                                    </td>
                                </tr>
                                <tr class="hover:bg-gray-50 transition">
                                    <td class="p-4 font-bold text-gray-800"><i class="fa-solid fa-shield-halved mr-2 text-secondary"></i>Chính sách bảo hành</td>
                                    <td class="p-4 font-mono text-gray-500 text-xs bg-gray-100 px-2 py-1 rounded inline-block mt-3">/chinh-sach-bao-hanh</td>
                                    <td class="p-4 text-gray-600">01/01/2026</td>
                                    <td class="p-4 text-center"><span class="bg-green-100 text-green-700 px-2.5 py-1 rounded-full text-xs font-semibold">Hiển thị</span></td>
                                    <td class="p-4 text-right">
                                        <button onclick="openPageModal()" class="text-blue-500 hover:text-blue-700 p-2"><i class="fa-solid fa-pen-to-square"></i></button>
                                        <button class="text-red-500 hover:text-red-700 p-2"><i class="fa-solid fa-trash-can"></i></button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<!-- Modal Thêm/Sửa Trang tĩnh -->
<div id="modal-page" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/50 backdrop-blur-sm transition-opacity">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-4xl mx-4 overflow-hidden flex flex-col h-[90vh] scale-95 transform transition-transform" id="modal-page-content">
        <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
            <h3 class="font-bold text-gray-800 text-lg">Biên Tập Nội Dung Trang</h3>
            <button onclick="closePageModal()" class="text-gray-400 hover:text-red-500 transition"><i class="fa-solid fa-xmark text-xl"></i></button>
        </div>
        <div class="p-6 overflow-y-auto flex-1 bg-gray-50">
            <form onsubmit="event.preventDefault(); closePageModal(); showAdminToast('Thành công', 'Đã lưu nội dung trang!', 'success');" class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
                <div class="grid grid-cols-2 gap-4 mb-4">
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Tên trang <span class="text-red-500">*</span></label><input type="text" class="w-full px-3 py-2 border border-gray-300 rounded outline-none focus:border-primary text-sm font-bold" required placeholder="VD: Giới thiệu công ty"></div>
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Đường dẫn (URL Slug) <span class="text-red-500">*</span></label><input type="text" class="w-full px-3 py-2 border border-gray-300 rounded outline-none focus:border-primary text-sm font-mono text-gray-500" required placeholder="VD: /about"></div>
                </div>
                <div class="mb-4"><label class="block text-sm font-medium text-gray-700 mb-1">Trạng thái hiển thị</label><select class="w-full md:w-1/3 px-3 py-2 border border-gray-300 rounded outline-none focus:border-primary text-sm"><option value="show">Hiển thị (Public)</option><option value="hide">Ẩn (Draft)</option></select></div>
                
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nội dung trang</label>
                    <div class="border border-gray-300 rounded overflow-hidden">
                        <div class="bg-gray-100 border-b border-gray-300 px-3 py-2 flex gap-2 text-gray-600 text-sm"><button type="button"><i class="fa-solid fa-bold"></i></button><button type="button"><i class="fa-solid fa-italic"></i></button><button type="button"><i class="fa-solid fa-image"></i></button></div>
                        <textarea rows="12" class="w-full px-4 py-3 outline-none text-sm resize-none" placeholder="Soạn thảo nội dung bằng HTML hoặc Text..."></textarea>
                    </div>
                </div>
                <div class="flex justify-end gap-3 pt-4 border-t border-gray-100"><button type="button" onclick="closePageModal()" class="bg-white border border-gray-300 text-gray-700 font-medium py-2 px-5 rounded hover:bg-gray-50 transition">Hủy bỏ</button><button type="submit" class="bg-primary text-white font-bold py-2 px-5 rounded hover:bg-blue-800 transition shadow">Cập Nhật Trang</button></div>
            </form>
        </div>
    </div>
</div>

<%- include('partials/scripts') %>
<script>
    function openPageModal() { const modal = document.getElementById('modal-page'); modal.classList.remove('hidden'); modal.classList.add('flex'); setTimeout(() => document.getElementById('modal-page-content').classList.remove('scale-95'), 10); }
    function closePageModal() { document.getElementById('modal-page-content').classList.add('scale-95'); setTimeout(() => { document.getElementById('modal-page').classList.add('hidden'); document.getElementById('modal-page').classList.remove('flex'); }, 200); }
</script>