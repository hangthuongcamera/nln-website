<%- include('partials/head', { title: 'Quản lý Giá - Admin Nhất Linh Nhi' }) %>

<div class="flex h-screen w-full">
    <div id="admin-toast-container" class="fixed top-20 right-6 z-50 flex flex-col gap-3 overflow-x-hidden p-2 pointer-events-none"></div>
    <%- include('partials/sidebar') %>

    <div class="flex-1 flex flex-col min-w-0 bg-gray-50">
        <%- include('partials/topbar', { pageTitle: 'Quản lý Giá' }) %>

        <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8">
            <div class="admin-page block animate-fade-in">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-800">Quản lý Giá</h2>
                        <p class="text-gray-500 text-sm mt-1">Cập nhật giá bán lẻ, giá sỉ và giá cũ cho sản phẩm.</p>
                    </div>
                    <div class="flex flex-wrap items-center gap-2">
                        <button type="button" onclick="resetFilters()" class="bg-white border border-gray-200 text-gray-700 font-semibold py-2.5 px-4 rounded-lg hover:bg-gray-50 transition text-sm flex items-center gap-2">
                            <i class="fa-solid fa-rotate-left"></i> Xóa lọc
                        </button>
                        <button onclick="exportPrices()" class="bg-white border border-green-200 text-green-700 font-semibold py-2.5 px-4 rounded-lg hover:bg-green-50 transition text-sm flex items-center gap-2">
                            <i class="fa-solid fa-file-export"></i> Xuất CSV
                        </button>
                        <button onclick="openImportModal()" class="bg-white border border-purple-200 text-purple-700 font-semibold py-2.5 px-4 rounded-lg hover:bg-purple-50 transition text-sm flex items-center gap-2">
                            <i class="fa-solid fa-file-import"></i> Nhập CSV
                        </button>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div id="price-stats" class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-3 mb-6">
                    <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm">
                        <p class="text-xs text-gray-500">Tổng sản phẩm</p>
                        <p class="text-2xl font-bold text-gray-800" data-stat="totalProducts">...</p>
                    </div>
                    <button type="button" onclick="quickFilter('priceStatus', 'missing')" class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm text-left hover:border-red-300 hover:bg-red-50 transition">
                        <p class="text-xs text-gray-500">Thiếu giá bán</p>
                        <p class="text-2xl font-bold text-red-600" data-stat="missingRetailPrice">...</p>
                    </button>
                    <button type="button" onclick="quickFilter('priceStatus', 'wholesale_missing')" class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm text-left hover:border-yellow-300 hover:bg-yellow-50 transition">
                        <p class="text-xs text-gray-500">Thiếu giá sỉ</p>
                        <p class="text-2xl font-bold text-yellow-600" data-stat="missingWholesalePrice">...</p>
                    </button>
                    <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm">
                        <p class="text-xs text-gray-500">Giá TB (bán lẻ)</p>
                        <p class="text-2xl font-bold text-blue-600" data-stat="avgRetailPrice">...</p>
                    </div>
                    <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm">
                        <p class="text-xs text-gray-500">Giá TB (sỉ)</p>
                        <p class="text-2xl font-bold text-purple-600" data-stat="avgWholesalePrice">...</p>
                    </div>
                </div>

                <!-- Filters -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
                        <div class="relative xl:col-span-2">
                            <input type="text" id="search-prices" placeholder="Tìm theo tên sản phẩm, SKU..." class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg outline-none focus:border-primary text-sm">
                            <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400"></i>
                        </div>

                        <select id="filter-category" class="border border-gray-300 rounded-lg px-3 py-2.5 outline-none focus:border-primary text-sm text-gray-700">
                            <option value="">Tất cả danh mục</option>
                        </select>

                        <select id="filter-price-status" class="border border-gray-300 rounded-lg px-3 py-2.5 outline-none focus:border-primary text-sm text-gray-700">
                            <option value="">Tất cả trạng thái</option>
                            <option value="has_price">Có giá bán</option>
                            <option value="missing">Thiếu giá bán</option>
                            <option value="wholesale_missing">Thiếu giá sỉ</option>
                        </select>

                        <select id="sort-prices" class="border border-gray-300 rounded-lg px-3 py-2.5 outline-none focus:border-primary text-sm text-gray-700">
                            <option value="updated_desc">Mới cập nhật</option>
                            <option value="updated_asc">Cũ nhất cập nhật</option>
                            <option value="name_asc">Tên A-Z</option>
                            <option value="name_desc">Tên Z-A</option>
                            <option value="price_asc">Giá thấp đến cao</option>
                            <option value="price_desc">Giá cao đến thấp</option>
                            <option value="wholesale_asc">Giá sỉ thấp đến cao</option>
                            <option value="wholesale_desc">Giá sỉ cao đến thấp</option>
                        </select>

                        <select id="page-limit" class="border border-gray-300 rounded-lg px-3 py-2.5 outline-none focus:border-primary text-sm text-gray-700">
                            <option value="50">50 dòng/trang</option>
                            <option value="100">100 dòng/trang</option>
                            <option value="20">20 dòng/trang</option>
                        </select>

                        <button onclick="loadPrices(1)" class="bg-blue-50 border border-blue-200 text-primary font-semibold py-2.5 px-4 rounded-lg hover:bg-blue-100 transition text-sm">
                            <i class="fa-solid fa-filter mr-1"></i> Áp dụng bộ lọc
                        </button>
                    </div>
                </div>

                <!-- Prices Table -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="p-4 border-b border-gray-100 flex flex-col md:flex-row justify-between items-start md:items-center gap-3 bg-white">
                        <div class="flex items-center gap-3">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox" id="select-all-prices" onchange="toggleSelectAll(this.checked)" class="w-4 h-4 text-primary border-gray-300 rounded focus:ring-primary">
                                <span class="text-sm text-gray-600">Chọn tất cả</span>
                            </label>
                            <div id="bulk-action-bar" class="hidden">
                                <span class="text-sm font-semibold text-primary" id="selected-count">0 sản phẩm được chọn</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button onclick="openBulkEditModal()" class="bg-primary text-white font-semibold py-2 px-4 rounded-lg hover:bg-blue-800 transition text-sm flex items-center gap-2">
                                <i class="fa-solid fa-edit"></i> Sửa hàng loạt
                            </button>
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-[1000px]">
                            <thead>
                                <tr class="bg-gray-50 text-gray-600 text-sm border-b border-gray-200">
                                    <th class="p-4 font-semibold w-10"></th>
                                    <th class="p-4 font-semibold">Sản phẩm</th>
                                    <th class="p-4 font-semibold">SKU</th>
                                    <th class="p-4 font-semibold">Danh mục</th>
                                    <th class="p-4 font-semibold text-right">Giá bán lẻ</th>
                                    <th class="p-4 font-semibold text-right">Giá cũ</th>
                                    <th class="p-4 font-semibold text-right">Giá sỉ</th>
                                    <th class="p-4 font-semibold text-right">Hành động</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm divide-y divide-gray-100" id="prices-tbody">
                                <tr><td colspan="8" class="p-4 text-center text-gray-500">Đang tải dữ liệu...</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="p-4 border-t border-gray-100 flex flex-col md:flex-row justify-between items-center gap-4 bg-gray-50">
                        <div class="text-sm text-gray-500" id="pagination-info">Hiển thị 0 sản phẩm</div>
                        <div class="flex items-center gap-1 flex-wrap justify-center" id="pagination-controls"></div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<!-- Import Modal -->
<div id="import-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4">
        <div class="p-6 border-b border-gray-100">
            <h3 class="text-lg font-bold text-gray-800"><i class="fa-solid fa-file-import mr-2 text-purple-600"></i>Nhập bảng giá từ CSV</h3>
        </div>
        <div class="p-6">
            <form id="import-form" enctype="multipart/form-data">
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Chọn file CSV</label>
                    <input type="file" id="import-file" accept=".csv" class="w-full border border-gray-300 rounded-lg p-2 text-sm">
                    <p class="text-xs text-gray-500 mt-1">File CSV gồm: sku, retailPrice (gia_ban), oldPrice (gia_cu), wholesalePrice (gia_si)</p>
                </div>
                <div class="flex justify-end gap-3">
                    <button type="button" onclick="closeImportModal()" class="px-4 py-2 text-gray-600 hover:bg-gray-100 rounded-lg">Hủy</button>
                    <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-blue-800">Tải lên</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Bulk Edit Modal -->
<div id="bulk-edit-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4">
        <div class="p-6 border-b border-gray-100">
            <h3 class="text-lg font-bold text-gray-800"><i class="fa-solid fa-edit mr-2 text-primary"></i>Sửa giá hàng loạt</h3>
        </div>
        <div class="p-6">
            <form id="bulk-edit-form">
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Giá bán lẻ</label>
                    <input type="number" id="bulk-retail-price" min="0" class="w-full border border-gray-300 rounded-lg p-2.5 text-sm" placeholder="Nhập giá bán lẻ mới">
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Giá cũ</label>
                    <input type="number" id="bulk-old-price" min="0" class="w-full border border-gray-300 rounded-lg p-2.5 text-sm" placeholder="Nhập giá cũ">
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Giá sỉ</label>
                    <input type="number" id="bulk-wholesale-price" min="0" class="w-full border border-gray-300 rounded-lg p-2.5 text-sm" placeholder="Nhập giá sỉ">
                </div>
                <p class="text-xs text-gray-500 mb-4">Để trống các trường không muốn thay đổi</p>
                <div class="flex justify-end gap-3">
                    <button type="button" onclick="closeBulkEditModal()" class="px-4 py-2 text-gray-600 hover:bg-gray-100 rounded-lg">Hủy</button>
                    <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-blue-800">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Price Modal -->
<div id="edit-price-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4">
        <div class="p-6 border-b border-gray-100">
            <h3 class="text-lg font-bold text-gray-800"><i class="fa-solid fa-tag mr-2 text-primary"></i>Cập nhật giá</h3>
        </div>
        <div class="p-6">
            <form id="edit-price-form">
                <input type="hidden" id="edit-price-product-id">
                <div class="mb-4">
                    <p class="text-sm text-gray-600 mb-2">Sản phẩm: <span id="edit-price-product-name" class="font-semibold text-gray-800"></span></p>
                    <p class="text-sm text-gray-600 mb-4">SKU: <span id="edit-price-product-sku" class="font-semibold text-gray-800"></span></p>
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Giá bán lẻ <span class="text-red-500">*</span></label>
                    <input type="number" id="edit-retail-price" min="0" class="w-full border border-gray-300 rounded-lg p-2.5 text-sm" required>
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Giá cũ</label>
                    <input type="number" id="edit-old-price" min="0" class="w-full border border-gray-300 rounded-lg p-2.5 text-sm">
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Giá sỉ</label>
                    <input type="number" id="edit-wholesale-price" min="0" class="w-full border border-gray-300 rounded-lg p-2.5 text-sm">
                </div>
                <div class="flex justify-end gap-3">
                    <button type="button" onclick="closeEditPriceModal()" class="px-4 py-2 text-gray-600 hover:bg-gray-100 rounded-lg">Hủy</button>
                    <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-blue-800">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('partials/scripts') %>
<script>
    const token = localStorage.getItem('token');
    let currentPage = 1;
    let selectedItems = new Set();

    document.addEventListener('DOMContentLoaded', () => {
        if (!token) window.location.href = '/admin/login';

        loadCategoryFilter();
        loadPriceStats();
        loadPrices();

        document.getElementById('search-prices').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') loadPrices(1);
        });

        ['filter-category', 'filter-price-status', 'sort-prices', 'page-limit'].forEach(id => {
            document.getElementById(id).addEventListener('change', () => loadPrices(1));
        });

        document.getElementById('import-form').addEventListener('submit', handleImport);
        document.getElementById('bulk-edit-form').addEventListener('submit', handleBulkEdit);
        document.getElementById('edit-price-form').addEventListener('submit', handleEditPrice);
    });

    async function loadPriceStats() {
        try {
            const res = await fetch('/api/v1/prices/stats', { headers: { 'Authorization': `Bearer ${token}` } });
            const data = await res.json();
            if (data.success) {
                document.querySelector('[data-stat="totalProducts"]').textContent = data.data.totalProducts;
                document.querySelector('[data-stat="missingRetailPrice"]').textContent = data.data.missingRetailPrice;
                document.querySelector('[data-stat="missingWholesalePrice"]').textContent = data.data.missingWholesalePrice;
                document.querySelector('[data-stat="avgRetailPrice"]').textContent = data.data.avgRetailPrice.toLocaleString('vi-VN') + 'đ';
                document.querySelector('[data-stat="avgWholesalePrice"]').textContent = data.data.avgWholesalePrice.toLocaleString('vi-VN') + 'đ';
            }
        } catch (error) {
            console.error('Error loading price stats:', error);
        }
    }

    async function loadCategoryFilter() {
        try {
            const res = await fetch('/api/v1/categories', { headers: { 'Authorization': `Bearer ${token}` } });
            const data = await res.json();
            if (data.success) {
                const select = document.getElementById('filter-category');
                data.data.forEach(cat => {
                    select.innerHTML += `<option value="${cat._id}">${cat.name}</option>`;
                });
            }
        } catch (error) {
            console.error('Error loading categories:', error);
        }
    }

    async function loadPrices(page = 1) {
        currentPage = page;
        const params = new URLSearchParams();
        params.set('page', page);
        params.set('limit', document.getElementById('page-limit').value);

        const search = document.getElementById('search-prices').value;
        if (search) params.set('search', search);

        const category = document.getElementById('filter-category').value;
        if (category) params.set('category', category);

        const priceStatus = document.getElementById('filter-price-status').value;
        if (priceStatus) params.set('priceStatus', priceStatus);

        const sort = document.getElementById('sort-prices').value;
        if (sort) params.set('sort', sort);

        try {
            const res = await fetch(`/api/v1/prices?${params}`, { headers: { 'Authorization': `Bearer ${token}` } });
            const data = await res.json();
            if (data.success) {
                renderPricesTable(data.data);
                renderPagination(data.pagination);
            }
        } catch (error) {
            console.error('Error loading prices:', error);
            showToast('Lỗi khi tải dữ liệu giá', 'error');
        }
    }

    function renderPricesTable(products) {
        const tbody = document.getElementById('prices-tbody');
        if (!products.length) {
            tbody.innerHTML = '<tr><td colspan="8" class="p-4 text-center text-gray-500">Không có sản phẩm nào</td></tr>';
            return;
        }

        tbody.innerHTML = products.map(product => {
            const retailPrice = product.retailPrice ? product.retailPrice.toLocaleString('vi-VN') + 'đ' : '<span class="text-red-600">Chưa có</span>';
            const oldPrice = product.oldPrice ? product.oldPrice.toLocaleString('vi-VN') + 'đ' : '-';
            const wholesalePrice = product.wholesalePrice ? product.wholesalePrice.toLocaleString('vi-VN') + 'đ' : '-';
            const missingPrice = !product.retailPrice || product.retailPrice <= 0;

            return `
                <tr class="hover:bg-gray-50 ${missingPrice ? 'bg-red-50/30' : ''}">
                    <td class="p-4">
                        <input type="checkbox" class="price-checkbox w-4 h-4 text-primary border-gray-300 rounded" value="${product._id}" onchange="toggleSelection('${product._id}')">
                    </td>
                    <td class="p-4">
                        <p class="font-medium text-gray-800">${product.name}</p>
                    </td>
                    <td class="p-4 text-gray-600">${product.sku}</td>
                    <td class="p-4 text-gray-600">${product.category?.name || '-'}</td>
                    <td class="p-4 text-right font-semibold ${missingPrice ? 'text-red-600' : 'text-gray-800'}">${retailPrice}</td>
                    <td class="p-4 text-right text-gray-600">${oldPrice}</td>
                    <td class="p-4 text-right text-gray-600">${wholesalePrice}</td>
                    <td class="p-4 text-right">
                        <button onclick='openEditPriceModal(${JSON.stringify({id: product._id, name: product.name, sku: product.sku, retailPrice: product.retailPrice || 0, oldPrice: product.oldPrice || 0, wholesalePrice: product.wholesalePrice || 0})})' class="text-primary hover:text-blue-800 font-medium text-sm">
                            <i class="fa-solid fa-edit mr-1"></i> Sửa
                        </button>
                    </td>
                </tr>
            `;
        }).join('');
    }

    function renderPagination(pagination) {
        const { total, page, pages } = pagination;
        document.getElementById('pagination-info').textContent = `Hiển thị ${total} sản phẩm (Trang ${page}/${pages})`;

        const controls = document.getElementById('pagination-controls');
        if (pages <= 1) {
            controls.innerHTML = '';
            return;
        }

        let html = '';
        if (page > 1) html += `<button onclick="loadPrices(${page - 1})" class="px-3 py-1 rounded border hover:bg-gray-100">‹</button>`;
        
        const start = Math.max(1, page - 2);
        const end = Math.min(pages, page + 2);
        
        if (start > 1) html += `<button onclick="loadPrices(1)" class="px-3 py-1 rounded border hover:bg-gray-100">1</button>`;
        if (start > 2) html += `<span class="px-2">...</span>`;
        
        for (let i = start; i <= end; i++) {
            html += `<button onclick="loadPrices(${i})" class="px-3 py-1 rounded border ${i === page ? 'bg-primary text-white' : 'hover:bg-gray-100'}">${i}</button>`;
        }
        
        if (end < pages - 1) html += `<span class="px-2">...</span>`;
        if (end < pages) html += `<button onclick="loadPrices(${pages})" class="px-3 py-1 rounded border hover:bg-gray-100">${pages}</button>`;
        
        if (page < pages) html += `<button onclick="loadPrices(${page + 1})" class="px-3 py-1 rounded border hover:bg-gray-100">›</button>`;
        
        controls.innerHTML = html;
    }

    function toggleSelectAll(checked) {
        document.querySelectorAll('.price-checkbox').forEach(cb => {
            cb.checked = checked;
            if (checked) selectedItems.add(cb.value);
            else selectedItems.delete(cb.value);
        });
        updateBulkActionBar();
    }

    function toggleSelection(id) {
        if (selectedItems.has(id)) selectedItems.delete(id);
        else selectedItems.add(id);
        updateBulkActionBar();
    }

    function updateBulkActionBar() {
        const bar = document.getElementById('bulk-action-bar');
        const count = document.getElementById('selected-count');
        if (selectedItems.size > 0) {
            bar.classList.remove('hidden');
            count.textContent = `${selectedItems.size} sản phẩm được chọn`;
        } else {
            bar.classList.add('hidden');
        }
    }

    function quickFilter(key, value) {
        if (key === 'priceStatus') {
            document.getElementById('filter-price-status').value = value;
        }
        loadPrices(1);
    }

    function resetFilters() {
        document.getElementById('search-prices').value = '';
        document.getElementById('filter-category').value = '';
        document.getElementById('filter-price-status').value = '';
        document.getElementById('sort-prices').value = 'updated_desc';
        loadPrices(1);
    }

    function openImportModal() {
        document.getElementById('import-modal').classList.remove('hidden');
        document.getElementById('import-modal').classList.add('flex');
    }

    function closeImportModal() {
        document.getElementById('import-modal').classList.add('hidden');
        document.getElementById('import-modal').classList.remove('flex');
        document.getElementById('import-form').reset();
    }

    async function handleImport(e) {
        e.preventDefault();
        const fileInput = document.getElementById('import-file');
        if (!fileInput.files[0]) {
            showToast('Vui lòng chọn file CSV', 'error');
            return;
        }

        const formData = new FormData();
        formData.append('file', fileInput.files[0]);

        try {
            const res = await fetch('/api/v1/prices/import', {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}` },
                body: formData
            });
            const data = await res.json();
            
            if (data.success) {
                showToast(data.message, 'success');
                closeImportModal();
                loadPriceStats();
                loadPrices(currentPage);
            } else {
                showToast(data.message, 'error');
            }
        } catch (error) {
            showToast('Lỗi khi import bảng giá', 'error');
        }
    }

    function openBulkEditModal() {
        if (selectedItems.size === 0) {
            showToast('Vui lòng chọn ít nhất một sản phẩm', 'warning');
            return;
        }
        document.getElementById('bulk-edit-modal').classList.remove('hidden');
        document.getElementById('bulk-edit-modal').classList.add('flex');
    }

    function closeBulkEditModal() {
        document.getElementById('bulk-edit-modal').classList.add('hidden');
        document.getElementById('bulk-edit-modal').classList.remove('flex');
        document.getElementById('bulk-edit-form').reset();
    }

    async function handleBulkEdit(e) {
        e.preventDefault();
        const retailPrice = document.getElementById('bulk-retail-price').value;
        const oldPrice = document.getElementById('bulk-old-price').value;
        const wholesalePrice = document.getElementById('bulk-wholesale-price').value;

        if (!retailPrice && !oldPrice && !wholesalePrice) {
            showToast('Vui lòng nhập ít nhất một giá trị cần cập nhật', 'warning');
            return;
        }

        const updates = Array.from(selectedItems).map(id => {
            const update = { productId: id };
            if (retailPrice) update.retailPrice = Number(retailPrice);
            if (oldPrice) update.oldPrice = Number(oldPrice);
            if (wholesalePrice) update.wholesalePrice = Number(wholesalePrice);
            return update;
        });

        try {
            const res = await fetch('/api/v1/prices/bulk', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ updates })
            });
            const data = await res.json();

            if (data.success) {
                showToast(data.message, 'success');
                closeBulkEditModal();
                selectedItems.clear();
                updateBulkActionBar();
                loadPriceStats();
                loadPrices(currentPage);
            } else {
                showToast(data.message, 'error');
            }
        } catch (error) {
            showToast('Lỗi khi cập nhật giá hàng loạt', 'error');
        }
    }

    function openEditPriceModal(product) {
        document.getElementById('edit-price-product-id').value = product.id;
        document.getElementById('edit-price-product-name').textContent = product.name;
        document.getElementById('edit-price-product-sku').textContent = product.sku;
        document.getElementById('edit-retail-price').value = product.retailPrice || 0;
        document.getElementById('edit-old-price').value = product.oldPrice || '';
        document.getElementById('edit-wholesale-price').value = product.wholesalePrice || '';
        document.getElementById('edit-price-modal').classList.remove('hidden');
        document.getElementById('edit-price-modal').classList.add('flex');
    }

    function closeEditPriceModal() {
        document.getElementById('edit-price-modal').classList.add('hidden');
        document.getElementById('edit-price-modal').classList.remove('flex');
    }

    async function handleEditPrice(e) {
        e.preventDefault();
        const productId = document.getElementById('edit-price-product-id').value;
        const retailPrice = document.getElementById('edit-retail-price').value;
        const oldPrice = document.getElementById('edit-old-price').value;
        const wholesalePrice = document.getElementById('edit-wholesale-price').value;

        try {
            const res = await fetch(`/api/v1/prices/${productId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({
                    retailPrice: Number(retailPrice),
                    oldPrice: oldPrice ? Number(oldPrice) : 0,
                    wholesalePrice: wholesalePrice ? Number(wholesalePrice) : 0
                })
            });
            const data = await res.json();

            if (data.success) {
                showToast('Cập nhật giá thành công', 'success');
                closeEditPriceModal();
                loadPriceStats();
                loadPrices(currentPage);
            } else {
                showToast(data.message, 'error');
            }
        } catch (error) {
            showToast('Lỗi khi cập nhật giá', 'error');
        }
    }

    function exportPrices() {
        const params = new URLSearchParams();
        const search = document.getElementById('search-prices').value;
        if (search) params.set('search', search);

        const category = document.getElementById('filter-category').value;
        if (category) params.set('category', category);

        const priceStatus = document.getElementById('filter-price-status').value;
        if (priceStatus) params.set('priceStatus', priceStatus);

        const sort = document.getElementById('sort-prices').value;
        if (sort) params.set('sort', sort);

        window.location.href = `/api/v1/prices/export?${params}`;
    }

    function showToast(message, type = 'info') {
        const container = document.getElementById('admin-toast-container');
        const toast = document.createElement('div');
        const bgColor = type === 'success' ? 'bg-green-500' : type === 'error' ? 'bg-red-500' : type === 'warning' ? 'bg-yellow-500' : 'bg-blue-500';
        toast.className = `${bgColor} text-white px-4 py-3 rounded-lg shadow-lg flex items-center gap-2 animate-slide-in`;
        toast.innerHTML = `<span>${message}</span>`;
        container.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }
</script>

<style>
    @keyframes slide-in {
        from { transform: translateX(100%); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }
    .animate-slide-in { animation: slide-in 0.3s ease-out; }
</style>
