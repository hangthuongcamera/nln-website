<!-- Cần thêm thư viện SortableJS để có thể kéo thả -->
<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
<%- include('partials/scripts') %>
<script>
    const token = localStorage.getItem('token');
    let currentPickerType = null; // 'hot' or 'flash_sale'
    let productToPin = null; // Biến lưu sản phẩm đang được chọn để ghim

    document.addEventListener('DOMContentLoaded', () => {
        if (!token) {
            window.location.href = '/admin/login';
            return;
        }
        loadSettings();
        loadPinnedProducts();
        initUspManager(); // Khởi tạo phần quản lý USP
        initProductPicker();
    });

    async function loadSettings() {
        try {
            const res = await fetch('/api/v1/settings', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const data = await res.json();

            if (res.ok && data.success && data.data) {
                const settings = data.data;

                // Populate Header USPs
                if (settings.headerUsps) {
                    const uspsContainer = document.getElementById('usps-container');
                    uspsContainer.innerHTML = settings.headerUsps.map((usp, index) => renderUspItem(usp, index)).join('');
                } else {
                    document.getElementById('usps-container').innerHTML = '';
                }

                // Populate Feature Flags
                document.getElementById('showMainBanner').checked = settings.uiFlags?.showMainBanner !== false;
                document.getElementById('showCategoriesCard').checked = settings.uiFlags?.showCategoriesCard !== false;
                document.getElementById('showFlashSale').checked = settings.uiFlags?.showFlashSale !== false;
                document.getElementById('showNewProducts').checked = settings.uiFlags?.showNewProducts !== false;
                document.getElementById('showNewsSection').checked = settings.uiFlags?.showNewsSection !== false;
                document.getElementById('searchSuggestionType').value = settings.uiFlags?.searchSuggestionType || 'newest';

                // Populate Flash Sale Config
                if (settings.flashSale?.endTime) {
                    const endTime = new Date(settings.flashSale.endTime);
                    // Format to YYYY-MM-DDTHH:MM for datetime-local input
                    const formattedEndTime = endTime.toISOString().slice(0, 16);
                    document.getElementById('flashSaleEndTime').value = formattedEndTime;
                }
                document.getElementById('flashSaleTitle').value = settings.flashSale?.title || ''; // Hiển thị chuỗi rỗng nếu không có tiêu đề

                // Populate Secondary Banners
                if (settings.secondaryBanners && settings.secondaryBanners[0]) {
                    document.getElementById('secondaryBanner1Img').src = settings.secondaryBanners[0].imageUrl || 'https://images.unsplash.com/photo-1621905251189-08b45d6a269e?auto=format&fit=crop&q=80&w=400';
                    document.getElementById('secondaryBanner1Link').value = settings.secondaryBanners[0].link || '';
                }
                if (settings.secondaryBanners && settings.secondaryBanners[1]) {
                    document.getElementById('secondaryBanner2Img').src = settings.secondaryBanners[1].imageUrl || 'https://images.unsplash.com/photo-1504148455328-c376907d081c?auto=format&fit=crop&q=80&w=400';
                    document.getElementById('secondaryBanner2Link').value = settings.secondaryBanners[1].link || '';
                }

                // TODO: Populate Main Banner Slider and Highlight Products

            } else {
                showAdminToast('Lỗi', data.message || 'Không thể tải cài đặt giao diện.', 'error');
            }
        } catch (error) {
            console.error('Lỗi khi tải cài đặt:', error);
            showAdminToast('Lỗi', 'Lỗi kết nối server khi tải cài đặt.', 'error');
        }
    }

    async function saveSettings() {
        const payload = {};

        // Collect Header USPs
        const uspItems = document.querySelectorAll('#usps-container .usp-item');
        payload.headerUsps = Array.from(uspItems).map(item => ({
            text: item.querySelector('input[name*="[text]"]').value.trim(),
            icon: item.querySelector('input[name*="[icon]"]').value.trim(),
            link: item.querySelector('input[name*="[link]"]').value.trim()
        })).filter(usp => usp.text); // Chỉ lưu những item có text


        // Collect Feature Flags
        payload.uiFlags = {
            showMainBanner: document.getElementById('showMainBanner').checked,
            showCategoriesCard: document.getElementById('showCategoriesCard').checked,
            showFlashSale: document.getElementById('showFlashSale').checked,
            showNewProducts: document.getElementById('showNewProducts').checked,
            showNewsSection: document.getElementById('showNewsSection').checked,
            searchSuggestionType: document.getElementById('searchSuggestionType').value
        };

        // Collect Flash Sale Config
        const flashSaleEndTime = document.getElementById('flashSaleEndTime').value;
        if (flashSaleEndTime) {
            payload.flashSale = {
                endTime: new Date(flashSaleEndTime).toISOString(), // Convert to ISO string for storage
                title: document.getElementById('flashSaleTitle').value.trim(),
            };
        } else {
            payload.flashSale = {
                endTime: null, // If input is empty, set endTime to null
                title: document.getElementById('flashSaleTitle').value.trim(),
            };
        }

        // Collect Secondary Banners (assuming fixed 2 banners for now)
        payload.secondaryBanners = [
            { imageUrl: document.getElementById('secondaryBanner1Img').src, link: document.getElementById('secondaryBanner1Link').value.trim() },
            { imageUrl: document.getElementById('secondaryBanner2Img').src, link: document.getElementById('secondaryBanner2Link').value.trim() },
        ];

        console.log('Payload sent to server:', payload); // Dòng này giúp bạn kiểm tra dữ liệu gửi đi

        try {
            const res = await fetch('/api/v1/settings', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (res.ok && data.success) {
                showAdminToast('Thành công', 'Đã lưu cấu hình giao diện!', 'success');
                loadSettings(); // Reload settings to ensure UI reflects saved data
            } else {
                let errorMessage = data.message || 'Không thể lưu cấu hình giao diện.';
                if (data.error) { // Hiển thị chi tiết lỗi từ server nếu có
                    errorMessage += ` Chi tiết: ${data.error}`;
                }
                showAdminToast('Lỗi', errorMessage, 'error');
            }
        } catch (error) {
            console.error('Lỗi khi lưu cài đặt:', error);
            showAdminToast('Lỗi', 'Lỗi kết nối server khi lưu cài đặt.', 'error');
        }
    }

    // --- USP Manager Logic ---
    function initUspManager() {
        const container = document.getElementById('usps-container');
        const addBtn = document.getElementById('add-usp-btn');

        addBtn.addEventListener('click', () => {
            const index = container.children.length;
            const newItem = renderUspItem({ text: '', icon: '', link: '' }, index);
            container.insertAdjacentHTML('beforeend', newItem);
        });

        container.addEventListener('click', (e) => {
            if (e.target.closest('.remove-usp-btn')) {
                e.target.closest('.usp-item').remove();
            }
        });

        new Sortable(container, {
            animation: 150,
            handle: '.usp-handle',
            ghostClass: 'bg-blue-50'
        });
    }

    function renderUspItem(usp, index) {
        return `
            <div class="usp-item flex items-center gap-2 p-2 bg-gray-50 rounded-lg border">
                <i class="usp-handle fa-solid fa-grip-vertical text-gray-400 cursor-move p-2" title="Kéo để sắp xếp"></i>
                <div class="flex-grow grid grid-cols-1 md:grid-cols-2 gap-2">
                    <input type="text" name="headerUsps[${index}][text]" value="${usp.text || ''}" placeholder="Nội dung (VD: Miễn phí vận chuyển)" class="w-full border border-gray-300 rounded-md px-3 py-2 outline-none focus:border-primary text-sm">
                    <div class="flex gap-2">
                        <input type="text" name="headerUsps[${index}][icon]" value="${usp.icon || ''}" placeholder="Icon (VD: fa-truck)" class="w-1/2 border border-gray-300 rounded-md px-3 py-2 outline-none focus:border-primary text-sm">
                        <input type="text" name="headerUsps[${index}][link]" value="${usp.link || ''}" placeholder="Link (VD: /khuyen-mai)" class="w-1/2 border border-gray-300 rounded-md px-3 py-2 outline-none focus:border-primary text-sm">
                    </div>
                </div>
                <button type="button" class="remove-usp-btn text-red-500 hover:text-red-700 p-2 rounded-full hover:bg-red-50" title="Xóa">
                    <i class="fa-solid fa-trash-can"></i>
                </button>
            </div>
        `;
    }
    // --- End USP Manager Logic ---


    async function loadPinnedProducts() {
        try {
            const [hotRes, flashRes] = await Promise.all([
                fetch('/api/v1/products?flag=hot&limit=100', { headers: { 'Authorization': `Bearer ${token}` } }),
                fetch('/api/v1/products?flag=flash_sale&limit=100', { headers: { 'Authorization': `Bearer ${token}` } })
            ]);

            const hotData = await hotRes.json();
            const flashData = await flashRes.json();

            if (hotData.success) {
                renderPinnedList('hot', hotData.data);
            }
            if (flashData.success) {
                renderPinnedList('flash_sale', flashData.data);
            }
        } catch (error) {
            console.error("Lỗi khi tải sản phẩm đã ghim:", error);
        }
    }

    function renderPinnedList(type, products) {
        const containerId = type === 'hot' ? 'pinned-hot-list' : 'pinned-flash-sale-list';
        const container = document.getElementById(containerId);
        if (!container) return;

        if (products.length === 0) {
            container.innerHTML = '<p class="text-center text-gray-500 text-sm p-4">Chưa có sản phẩm nào được ghim.</p>';
            return;
        }

        container.innerHTML = products.map(p => `
            <div class="flex justify-between items-center bg-white p-2 rounded border border-gray-200 text-sm shadow-sm group">
                <span class="line-clamp-1 font-medium text-gray-700" title="${p.name}">${p.name}</span>
                <button onclick="unpinProduct('${p._id}', '${type}')" class="text-gray-400 hover:text-red-500 transition px-2" title="Bỏ ghim">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        `).join('');
    }

    async function unpinProduct(productId, type) {
        const flagName = type === 'hot' ? 'isHot' : 'isFlashSale';
        const payload = {
            flags: { [flagName]: false }
        };

        try {
            const res = await fetch(`/api/v1/products/${productId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (res.ok && data.success) {
                showAdminToast('Thành công', 'Đã bỏ ghim sản phẩm.', 'success');
                loadPinnedProducts(); // Refresh both lists
            } else {
                showAdminToast('Lỗi', data.message || 'Không thể bỏ ghim sản phẩm.', 'error');
            }
        } catch (error) {
            showAdminToast('Lỗi', 'Lỗi kết nối server.', 'error');
        }
    }

    // --- Flash Sale Price Modal Logic ---
    const flashSalePriceModal = document.getElementById('flash-sale-price-modal');
    const flashSalePriceInput = document.getElementById('flash-sale-price-input');
    const flashSaleProductName = document.getElementById('flash-sale-product-name');
    const flashSaleCurrentPrice = document.getElementById('flash-sale-current-price');
    const flashSaleOldPrice = document.getElementById('flash-sale-old-price');
    const confirmFlashSalePriceBtn = document.getElementById('confirm-flash-sale-price-btn');

    function openFlashSalePriceModal(product) {
        productToPin = product; // Store the product object
        if (flashSalePriceModal) {
            flashSalePriceModal.classList.remove('hidden');
            flashSaleProductName.textContent = product.name;
            flashSaleCurrentPrice.textContent = product.retailPrice ? product.retailPrice.toLocaleString('vi-VN') + 'đ' : 'Liên hệ';
            flashSaleOldPrice.textContent = product.oldPrice ? product.oldPrice.toLocaleString('vi-VN') + 'đ' : 'Không có';
            flashSalePriceInput.value = ''; // Xóa giá trị cũ
            flashSalePriceInput.placeholder = `Nhập giá thấp hơn ${product.retailPrice.toLocaleString('vi-VN')}đ`;
            confirmFlashSalePriceBtn.onclick = () => confirmFlashSalePrice();
        }
    }

    function closeFlashSalePriceModal() {
        if (flashSalePriceModal) {
            flashSalePriceModal.classList.add('hidden');
            productToPin = null;
        }
    }

    async function confirmFlashSalePrice() {
        const price = parseFloat(flashSalePriceInput.value);
        if (isNaN(price) || price < 0) {
            return showAdminToast('Lỗi', 'Vui lòng nhập giá Flash Sale hợp lệ (số dương).', 'error');
        }
        if (productToPin && price >= productToPin.retailPrice) {
            return showAdminToast('Cảnh báo', 'Giá Flash Sale phải thấp hơn giá bán hiện tại.', 'warning');
        }

        const confirmBtn = document.getElementById('confirm-flash-sale-price-btn');
        const originalBtnHtml = confirmBtn.innerHTML;
        confirmBtn.disabled = true;
        confirmBtn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> Đang xử lý...`;

        try {
            // Let pinProduct handle everything, including closing modals
            await pinProduct(productToPin._id, 'flash_sale', price);
        } finally {
            // Restore button state in case of failure and the modal is still open
            confirmBtn.disabled = false;
            confirmBtn.innerHTML = originalBtnHtml;
        }
    }

    function openProductPicker(type) {
        currentPickerType = type;
        const modal = document.getElementById('product-picker-modal');
        if (modal) {
            modal.classList.remove('hidden');
            document.getElementById('picker-search-input').value = '';
            // Clear previous results and load default products
            const resultsContainer = document.getElementById('picker-search-results');
            if (resultsContainer) {
                resultsContainer.innerHTML = '<div class="text-center text-gray-500 p-8">Đang tải sản phẩm...</div>';
            }
            fetchAndRenderPickerResults(''); // Tải sản phẩm mặc định khi mở modal
        }
    }

    function closeProductPickerModal() {
        const modal = document.getElementById('product-picker-modal');
        if (modal) {
            modal.classList.add('hidden');
        }
    }

    function initProductPicker() {
        const searchInput = document.getElementById('picker-search-input');
        if (!searchInput) return;

        let searchTimeout;
        // Event listener cho ô tìm kiếm
        searchInput.addEventListener('input', (e) => {
            clearTimeout(searchTimeout);
            const query = e.target.value.trim();
            if (query.length < 2) {
                resultsContainer.innerHTML = '<div class="text-center text-gray-500 p-8">Nhập ít nhất 2 ký tự để tìm...</div>';
                return;
            }
            searchTimeout = setTimeout(() => fetchAndRenderPickerResults(query), 500); // Chờ 500ms trước khi tìm kiếm
        });
    }

    async function fetchAndRenderPickerResults(query) {
        const resultsContainer = document.getElementById('picker-search-results');
        if (!resultsContainer) return;

        resultsContainer.innerHTML = '<div class="text-center text-gray-500 p-8"><i class="fa-solid fa-spinner fa-spin mr-2"></i>Đang tìm kiếm...</div>';

        try {
            // Nếu query rỗng, tải 20 sản phẩm mới nhất. Ngược lại, tìm kiếm theo query.
            const url = query ? `/api/v1/products?search=${encodeURIComponent(query)}&limit=50` : `/api/v1/products?limit=20&sort=newest`;
            const res = await fetch(url, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const data = await res.json();
            if (data.success && data.data.length > 0) {
                resultsContainer.innerHTML = data.data.map(p => {
                    const isHot = p.flags?.isHot;
                    const isFlash = p.flags?.isFlashSale;
                    let btnHtml = '';
                    if (currentPickerType === 'hot') {
                        btnHtml = isHot 
                            ? '<button class="bg-gray-200 text-gray-500 text-xs font-bold py-1 px-3 rounded-full cursor-not-allowed" disabled>Đã Ghim</button>'
                            : `<button onclick="pinProduct('${p._id}', 'hot')" class="bg-green-100 text-green-700 hover:bg-green-600 hover:text-white text-xs font-bold py-1 px-3 rounded-full transition">Ghim Bán Chạy</button>`;
                    } else if (currentPickerType === 'flash_sale') {
                                btnHtml = isFlash
                            ? '<button class="bg-gray-200 text-gray-500 text-xs font-bold py-1 px-3 rounded-full cursor-not-allowed" disabled>Đã Ghim</button>'
                                    : `<button onclick='openFlashSalePriceModal(${JSON.stringify(p)})' class="bg-red-100 text-red-700 hover:bg-red-600 hover:text-white text-xs font-bold py-1 px-3 rounded-full transition">Ghim Flash Sale</button>`;
                    }

                    return `
                        <div class="flex items-center justify-between p-2 bg-white rounded border border-gray-200 mb-2">
                            <div class="flex items-center gap-3 min-w-0">
                                <img src="${p.images && p.images.length > 0 ? p.images[0] : '/img/placeholder.png'}" class="w-10 h-10 object-cover rounded flex-shrink-0">
                                <div class="min-w-0">
                                    <p class="text-sm font-semibold text-gray-800 truncate" title="${p.name}">${p.name}</p>
                                    <p class="text-xs text-gray-500 font-mono">${p.sku}</p>
                                            <p class="text-xs text-gray-700 font-semibold">Giá bán: ${p.retailPrice ? p.retailPrice.toLocaleString('vi-VN') + 'đ' : 'Liên hệ'}</p>
                                            ${p.oldPrice && p.oldPrice > 0 ? `<p class="text-xs text-gray-400 line-through">Giá cũ: ${p.oldPrice.toLocaleString('vi-VN')}đ</p>` : ''}
                                </div>
                            </div>
                            <div class="flex-shrink-0 ml-2">${btnHtml}</div>
                        </div>`;
                }).join('');
            } else {
                resultsContainer.innerHTML = `<div class="text-center text-gray-500 p-8">Không tìm thấy sản phẩm nào.</div>`;
            }
        } catch (error) {
            resultsContainer.innerHTML = `<div class="text-center text-red-500 p-8">Lỗi khi tìm kiếm sản phẩm.</div>`;
        }
    }

    async function pinProduct(productId, type, flashSalePrice = null) { // Add flashSalePrice parameter
        const flagName = type === 'hot' ? 'isHot' : 'isFlashSale';
        let payload = { flags: { [flagName]: true } };

        if (type === 'flash_sale') {
            if (flashSalePrice !== null) payload.flashSalePrice = parseFloat(flashSalePrice);
        }

        try {
            const res = await fetch(`/api/v1/products/${productId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (res.ok && data.success) {
                showAdminToast('Thành công', 'Đã ghim sản phẩm.', 'success');
                loadPinnedProducts(); // Refresh lists on the main page
                closeFlashSalePriceModal(); // Close the price modal
                closeProductPickerModal(); // Close the picker modal
            } else {
                showAdminToast('Lỗi', data.message || 'Không thể ghim sản phẩm.', 'error');
            }
        } catch (error) {
            showAdminToast('Lỗi', 'Lỗi kết nối server.', 'error');
        }
    }
</script>