<%- include('partials/head', { title: 'Quản lý Thương hiệu - Admin Nhất Linh Nhi' }) %>

<div class="flex h-screen w-full">
    <div id="admin-toast-container" class="fixed top-20 right-6 z-50 flex flex-col gap-3 overflow-x-hidden p-2 pointer-events-none"></div>
    <%- include('partials/sidebar') %>

    <div class="flex-1 flex flex-col min-w-0 bg-gray-50">
        <%- include('partials/topbar', { pageTitle: 'Quản lý Thương Hiệu' }) %>

        <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8">
            <div class="admin-page block animate-fade-in">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-800">Thương Hiệu Đối Tác</h2>
                        <p class="text-gray-500 text-sm mt-1">Quản lý danh sách logo thương hiệu hiển thị trên băng chuyền trang chủ.</p>
                    </div>
                    <button onclick="openBrandModal()" class="bg-primary text-white font-bold py-2.5 px-5 rounded-lg hover:bg-blue-800 transition shadow-md flex items-center gap-2">
                        <i class="fa-solid fa-plus"></i> Thêm Thương Hiệu
                    </button>
                </div>

                <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
                        <!-- Brand Item -->
                        <div class="border border-gray-200 rounded-lg p-4 flex flex-col items-center justify-center relative group hover:border-primary transition">
                            <img src="https://upload.wikimedia.org/wikipedia/commons/e/e3/Panasonic_logo_%28Blue%29.svg" alt="Panasonic" class="h-10 object-contain mb-3">
                            <span class="text-sm font-semibold text-gray-700">Panasonic</span>
                            <div class="absolute inset-0 bg-white/90 flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100 transition rounded-lg">
                                <button onclick="openBrandModal()" class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center hover:bg-blue-600 hover:text-white transition"><i class="fa-solid fa-pen"></i></button>
                                <button class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center hover:bg-red-600 hover:text-white transition"><i class="fa-solid fa-trash"></i></button>
                            </div>
                        </div>
                        <!-- Brand Item Text -->
                        <div class="border border-gray-200 rounded-lg p-4 flex flex-col items-center justify-center relative group hover:border-primary transition">
                            <div class="h-10 flex items-center justify-center mb-3"><span class="text-xl font-black text-gray-500">BÌNH MINH</span></div>
                            <span class="text-sm font-semibold text-gray-700">Bình Minh</span>
                            <div class="absolute inset-0 bg-white/90 flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100 transition rounded-lg">
                                <button onclick="openBrandModal()" class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center hover:bg-blue-600 hover:text-white transition"><i class="fa-solid fa-pen"></i></button>
                                <button class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center hover:bg-red-600 hover:text-white transition"><i class="fa-solid fa-trash"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<!-- Modal Thêm/Sửa Thương hiệu -->
<div id="modal-brand" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/50 backdrop-blur-sm transition-opacity">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4 overflow-hidden flex flex-col scale-95 transform transition-transform" id="modal-brand-content">
        <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
            <h3 class="font-bold text-gray-800 text-lg">Thêm Thương Hiệu</h3>
            <button onclick="closeBrandModal()" class="text-gray-400 hover:text-red-500 transition"><i class="fa-solid fa-xmark text-xl"></i></button>
        </div>
        <div class="p-6">
            <form onsubmit="event.preventDefault(); closeBrandModal(); showAdminToast('Thành công', 'Đã lưu thương hiệu!', 'success');">
                <div class="mb-4"><label class="block text-sm font-medium text-gray-700 mb-1">Tên thương hiệu <span class="text-red-500">*</span></label><input type="text" class="w-full px-3 py-2 border border-gray-300 rounded outline-none focus:border-primary text-sm" required></div>
                <div class="mb-5"><label class="block text-sm font-medium text-gray-700 mb-1">Logo thương hiệu <span class="text-red-500">*</span></label>
                    <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:bg-gray-50 transition cursor-pointer mb-2"><i class="fa-solid fa-cloud-arrow-up text-3xl text-gray-400 mb-2"></i><p class="text-xs font-medium text-gray-700">Kéo thả logo hoặc chọn tệp (PNG nền trong suốt)</p></div>
                </div>
                <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
                    <button type="button" onclick="closeBrandModal()" class="bg-white border border-gray-300 text-gray-700 font-medium py-2 px-5 rounded hover:bg-gray-50 transition">Hủy</button>
                    <button type="submit" class="bg-primary text-white font-bold py-2 px-5 rounded hover:bg-blue-800 transition">Lưu Thay Đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('partials/scripts') %>
<script>
    function openBrandModal() { const modal = document.getElementById('modal-brand'); modal.classList.remove('hidden'); modal.classList.add('flex'); setTimeout(() => document.getElementById('modal-brand-content').classList.remove('scale-95'), 10); }
    function closeBrandModal() { document.getElementById('modal-brand-content').classList.add('scale-95'); setTimeout(() => { document.getElementById('modal-brand').classList.add('hidden'); document.getElementById('modal-brand').classList.remove('flex'); }, 200); }
</script>