<%- include('partials/head', { title: 'Cấu hình hệ thống - Admin Nhất Linh Nhi' }) %>

<div class="flex h-screen w-full">
    <%- include('partials/sidebar') %>
    
    <div class="flex-1 flex flex-col overflow-hidden">
        <%- include('partials/topbar') %>
        
        <main class="flex-1 overflow-y-auto bg-gray-50">

<div class="p-6">
    <h1 class="text-2xl font-bold text-gray-800 mb-6">Cấu hình hệ thống</h1>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Settings Form -->
        <div class="lg:col-span-2">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h2 class="text-lg font-semibold mb-4">Thông tin website</h2>
                <form id="settingsForm" class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Tên website</label>
                            <input type="text" id="siteName" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Mô tả</label>
                            <input type="text" id="siteDescription" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại</label>
                            <input type="text" id="phone" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                            <input type="email" id="email" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Địa chỉ</label>
                        <input type="text" id="address" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                    </div>

                    <h3 class="text-lg font-semibold pt-4">Mạng xã hội</h3>
                    <div class="grid grid-cols-3 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Facebook</label>
                            <input type="url" id="facebook" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Zalo</label>
                            <input type="text" id="zalo" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Youtube</label>
                            <input type="url" id="youtube" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                        </div>
                    </div>

                    <div class="flex justify-end gap-3 pt-4">
                        <button type="button" onclick="loadSettings()" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">Hủy</button>
                        <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Lưu cấu hình</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Server Status & Quick Actions -->
        <div class="space-y-6">
            <!-- Server Status -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h2 class="text-lg font-semibold mb-4">Trạng thái server</h2>
                <div id="serverStatus" class="space-y-3">
                    <div class="flex justify-between"><span class="text-gray-500">Database</span><span class="font-medium" id="dbStatus">-</span></div>
                    <div class="flex justify-between"><span class="text-gray-500">Uptime</span><span class="font-medium" id="uptime">-</span></div>
                    <div class="flex justify-between"><span class="text-gray-500">Memory</span><span class="font-medium" id="memory">-</span></div>
                    <div class="flex justify-between"><span class="text-gray-500">Node.js</span><span class="font-medium" id="nodeVersion">-</span></div>
                </div>
                <button onclick="loadServerStatus()" class="mt-4 w-full px-4 py-2 bg-gray-100 rounded-lg hover:bg-gray-200 text-sm">Làm mới</button>
            </div>

            <!-- Maintenance Mode -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h2 class="text-lg font-semibold mb-4">Chế độ bảo trì</h2>
                <div class="flex items-center justify-between mb-4">
                    <span class="text-gray-600">Bật/Tắt bảo trì</span>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" id="maintenanceToggle" class="sr-only peer" onchange="toggleMaintenance()">
                        <div class="w-11 h-6 bg-gray-200 peer-focus:ring-2 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                    </label>
                </div>
                <input type="text" id="maintenanceMessage" placeholder="Thông báo bảo trì" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
            </div>

            <!-- Quick Stats -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h2 class="text-lg font-semibold mb-4">Thống kê nhanh</h2>
                <div class="space-y-3">
                    <div class="flex justify-between"><span class="text-gray-500">Sản phẩm</span><span class="font-medium" id="productCount">-</span></div>
                    <div class="flex justify-between"><span class="text-gray-500">Người dùng</span><span class="font-medium" id="userCount">-</span></div>
                    <div class="flex justify-between"><span class="text-gray-500">Đơn hàng</span><span class="font-medium" id="orderCount">-</span></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    loadSettings();
    loadServerStatus();
    
    document.getElementById('settingsForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        await saveSettings();
    });
});

async function loadSettings() {
    try {
        const res = await fetch('/api/v1/system/config', {
            headers: { 'Authorization': `Bearer ${getToken()}` }
        });
        const data = await res.json();
        if (data.success) {
            const config = data.data;
            document.getElementById('siteName').value = config.siteName || '';
            document.getElementById('siteDescription').value = config.siteDescription || '';
            document.getElementById('phone').value = config.contact?.phone || '';
            document.getElementById('email').value = config.contact?.email || '';
            document.getElementById('address').value = config.contact?.address || '';
            document.getElementById('facebook').value = config.social?.facebook || '';
            document.getElementById('zalo').value = config.social?.zalo || '';
            document.getElementById('youtube').value = config.social?.youtube || '';
            document.getElementById('maintenanceToggle').checked = config.maintenance?.enabled || false;
            document.getElementById('maintenanceMessage').value = config.maintenance?.message || '';
        }
    } catch (error) { console.error('Error:', error); }
}

async function saveSettings() {
    const config = {
        siteName: document.getElementById('siteName').value,
        siteDescription: document.getElementById('siteDescription').value,
        contact: {
            phone: document.getElementById('phone').value,
            email: document.getElementById('email').value,
            address: document.getElementById('address').value
        },
        social: {
            facebook: document.getElementById('facebook').value,
            zalo: document.getElementById('zalo').value,
            youtube: document.getElementById('youtube').value
        }
    };
    
    try {
        const res = await fetch('/api/v1/system/config', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${getToken()}` },
            body: JSON.stringify(config)
        });
        const data = await res.json();
        showToast(data.success ? 'Lưu thành công!' : 'Có lỗi xảy ra', data.success ? 'success' : 'error');
    } catch (error) { showToast('Có lỗi xảy ra', 'error'); }
}

async function loadServerStatus() {
    try {
        const res = await fetch('/api/v1/system/status', {
            headers: { 'Authorization': `Bearer ${getToken()}` }
        });
        const data = await res.json();
        if (data.success) {
            const s = data.data;
            document.getElementById('dbStatus').textContent = s.database;
            document.getElementById('dbStatus').className = `font-medium ${s.database === 'connected' ? 'text-green-600' : 'text-red-600'}`;
            document.getElementById('uptime').textContent = formatUptime(s.uptime);
            document.getElementById('memory').textContent = `${s.memory.used}/${s.memory.total} MB`;
            document.getElementById('nodeVersion').textContent = s.nodeVersion;
            document.getElementById('productCount').textContent = s.counts.products;
            document.getElementById('userCount').textContent = s.counts.users;
            document.getElementById('orderCount').textContent = s.counts.orders;
        }
    } catch (error) { console.error('Error:', error); }
}

async function toggleMaintenance() {
    const enabled = document.getElementById('maintenanceToggle').checked;
    const message = document.getElementById('maintenanceMessage').value;
    try {
        const res = await fetch('/api/v1/system/maintenance', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${getToken()}` },
            body: JSON.stringify({ enabled, message })
        });
        const data = await res.json();
        showToast(data.message, data.success ? 'success' : 'error');
    } catch (error) { showToast('Có lỗi xảy ra', 'error'); }
}

function formatUptime(seconds) {
    const d = Math.floor(seconds / 86400);
    const h = Math.floor((seconds % 86400) / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    return `${d}d ${h}h ${m}m`;
}

function showToast(message, type = 'info') {
    const toast = document.createElement('div');
    toast.className = `fixed bottom-4 right-4 px-4 py-3 rounded-lg shadow-lg z-50 ${type === 'success' ? 'bg-green-600' : type === 'error' ? 'bg-red-600' : 'bg-blue-600'} text-white`;
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
}

function getToken() { return localStorage.getItem('token') || ''; }
</script>

        </main>
    </div>
</div>

<%- include('partials/scripts') %>
