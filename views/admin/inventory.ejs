<%- include('partials/head', { title: 'Quản lý Tồn kho - Admin Nhất Linh Nhi' }) %>

<div class="flex h-screen w-full">
    <div id="admin-toast-container" class="fixed top-20 right-6 z-50 flex flex-col gap-3 overflow-x-hidden p-2 pointer-events-none"></div>
    <%- include('partials/sidebar') %>

    <div class="flex-1 flex flex-col min-w-0 bg-gray-50">
        <%- include('partials/topbar', { pageTitle: 'Quản lý Tồn kho' }) %>

        <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8">
            <div class="admin-page block animate-fade-in">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-800">Quản lý Tồn kho</h2>
                        <p class="text-gray-500 text-sm mt-1">Theo dõi và cập nhật tồn kho sản phẩm, hỗ trợ import/export Excel.</p>
                    </div>
                    <div class="flex flex-wrap items-center gap-2">
                        <button type="button" onclick="resetFilters()" class="bg-white border border-gray-200 text-gray-700 font-semibold py-2.5 px-4 rounded-lg hover:bg-gray-50 transition text-sm flex items-center gap-2">
                            <i class="fa-solid fa-rotate-left"></i> Xóa lọc
                        </button>
                        <button onclick="exportInventory()" class="bg-white border border-green-200 text-green-700 font-semibold py-2.5 px-4 rounded-lg hover:bg-green-50 transition text-sm flex items-center gap-2">
                            <i class="fa-solid fa-file-export"></i> Xuất CSV
                        </button>
                        <button onclick="openImportModal()" class="bg-white border border-purple-200 text-purple-700 font-semibold py-2.5 px-4 rounded-lg hover:bg-purple-50 transition text-sm flex items-center gap-2">
                            <i class="fa-solid fa-file-import"></i> Nhập CSV
                        </button>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div id="inventory-stats" class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-3 mb-6">
                    <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm">
                        <p class="text-xs text-gray-500">Tổng sản phẩm</p>
                        <p class="text-2xl font-bold text-gray-800" data-stat="totalProducts">...</p>
                    </div>
                    <button type="button" onclick="quickFilter('stockStatus', 'in_stock')" class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm text-left hover:border-green-300 hover:bg-green-50 transition">
                        <p class="text-xs text-gray-500">Còn hàng</p>
                        <p class="text-2xl font-bold text-green-600" data-stat="inStock">...</p>
                    </button>
                    <button type="button" onclick="quickFilter('stockStatus', 'low_stock')" class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm text-left hover:border-yellow-300 hover:bg-yellow-50 transition">
                        <p class="text-xs text-gray-500">Sắp hết hàng</p>
                        <p class="text-2xl font-bold text-yellow-600" data-stat="lowStock">...</p>
                    </button>
                    <button type="button" onclick="quickFilter('stockStatus', 'out_of_stock')" class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm text-left hover:border-red-300 hover:bg-red-50 transition">
                        <p class="text-xs text-gray-500">Hết hàng</p>
                        <p class="text-2xl font-bold text-red-600" data-stat="outOfStock">...</p>
                    </button>
                    <button type="button" onclick="quickFilter('stockStatus', 'negative')" class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm text-left hover:border-red-300 hover:bg-red-50 transition">
                        <p class="text-xs text-gray-500">Tồn kho âm</p>
                        <p class="text-2xl font-bold text-red-700" data-stat="negativeStock">...</p>
                    </button>
                </div>

                <!-- Filters -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
                        <div class="relative xl:col-span-2">
                            <input type="text" id="search-inventory" placeholder="Tìm theo tên sản phẩm, SKU..." class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg outline-none focus:border-primary text-sm">
                            <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400"></i>
                        </div>

                        <select id="filter-category" class="border border-gray-300 rounded-lg px-3 py-2.5 outline-none focus:border-primary text-sm text-gray-700">
                            <option value="">Tất cả danh mục</option>
                        </select>

                        <select id="filter-stock-status" class="border border-gray-300 rounded-lg px-3 py-2.5 outline-none focus:border-primary text-sm text-gray-700">
                            <option value="">Tất cả trạng thái</option>
                            <option value="in_stock">Còn hàng</option>
                            <option value="low_stock">Sắp hết hàng</option>
                            <option value="out_of_stock">Hết hàng</option>
                            <option value="negative">Tồn kho âm</option>
                        </select>

                        <select id="sort-inventory" class="border border-gray-300 rounded-lg px-3 py-2.5 outline-none focus:border-primary text-sm text-gray-700">
                            <option value="updated_desc">Mới cập nhật</option>
                            <option value="updated_asc">Cũ nhất cập nhật</option>
                            <option value="name_asc">Tên A-Z</option>
                            <option value="name_desc">Tên Z-A</option>
                            <option value="stock_asc">Tồn kho thấp đến cao</option>
                            <option value="stock_desc">Tồn kho cao đến thấp</option>
                        </select>

                        <select id="page-limit" class="border border-gray-300 rounded-lg px-3 py-2.5 outline-none focus:border-primary text-sm text-gray-700">
                            <option value="50">50 dòng/trang</option>
                            <option value="100">100 dòng/trang</option>
                            <option value="20">20 dòng/trang</option>
                        </select>

                        <button onclick="loadInventory(1)" class="bg-blue-50 border border-blue-200 text-primary font-semibold py-2.5 px-4 rounded-lg hover:bg-blue-100 transition text-sm">
                            <i class="fa-solid fa-filter mr-1"></i> Áp dụng bộ lọc
                        </button>
                    </div>
                </div>

                <!-- Inventory Table -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="p-4 border-b border-gray-100 flex flex-col md:flex-row justify-between items-start md:items-center gap-3 bg-white">
                        <div class="flex items-center gap-3">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox" id="select-all-inventory" onchange="toggleSelectAll(this.checked)" class="w-4 h-4 text-primary border-gray-300 rounded focus:ring-primary">
                                <span class="text-sm text-gray-600">Chọn tất cả</span>
                            </label>
                            <div id="bulk-action-bar" class="hidden">
                                <span class="text-sm font-semibold text-primary" id="selected-count">0 sản phẩm được chọn</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button onclick="openBulkEditModal()" class="bg-primary text-white font-semibold py-2 px-4 rounded-lg hover:bg-blue-800 transition text-sm flex items-center gap-2">
                                <i class="fa-solid fa-edit"></i> Sửa hàng loạt
                            </button>
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-[900px]">
                            <thead>
                                <tr class="bg-gray-50 text-gray-600 text-sm border-b border-gray-200">
                                    <th class="p-4 font-semibold w-10"></th>
                                    <th class="p-4 font-semibold">Sản phẩm</th>
                                    <th class="p-4 font-semibold">SKU</th>
                                    <th class="p-4 font-semibold">Danh mục</th>
                                    <th class="p-4 font-semibold text-center">Tồn kho</th>
                                    <th class="p-4 font-semibold text-center">Trạng thái</th>
                                    <th class="p-4 font-semibold text-right">Hành động</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm divide-y divide-gray-100" id="inventory-tbody">
                                <tr><td colspan="7" class="p-4 text-center text-gray-500">Đang tải dữ liệu...</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="p-4 border-t border-gray-100 flex flex-col md:flex-row justify-between items-center gap-4 bg-gray-50">
                        <div class="text-sm text-gray-500" id="pagination-info">Hiển thị 0 sản phẩm</div>
                        <div class="flex items-center gap-1 flex-wrap justify-center" id="pagination-controls"></div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<!-- Import Modal -->
<div id="import-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4">
        <div class="p-6 border-b border-gray-100">
            <h3 class="text-lg font-bold text-gray-800"><i class="fa-solid fa-file-import mr-2 text-purple-600"></i>Nhập tồn kho từ CSV</h3>
        </div>
        <div class="p-6">
            <form id="import-form" enctype="multipart/form-data">
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Chọn file CSV</label>
                    <input type="file" id="import-file" accept=".csv" class="w-full border border-gray-300 rounded-lg p-2 text-sm">
                    <p class="text-xs text-gray-500 mt-1">File CSV gồm các cột: sku, stock (hoặc ton_kho)</p>
                </div>
                <div class="flex justify-end gap-3">
                    <button type="button" onclick="closeImportModal()" class="px-4 py-2 text-gray-600 hover:bg-gray-100 rounded-lg">Hủy</button>
                    <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-blue-800">Tải lên</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Bulk Edit Modal -->
<div id="bulk-edit-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4">
        <div class="p-6 border-b border-gray-100">
            <h3 class="text-lg font-bold text-gray-800"><i class="fa-solid fa-edit mr-2 text-primary"></i>Sửa tồn kho hàng loạt</h3>
        </div>
        <div class="p-6">
            <form id="bulk-edit-form">
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Số lượng tồn kho mới</label>
                    <input type="number" id="bulk-stock" min="0" class="w-full border border-gray-300 rounded-lg p-2.5 text-sm" placeholder="Nhập số lượng mới">
                    <p class="text-xs text-gray-500 mt-1">Để trống nếu không muốn thay đổi</p>
                </div>
                <div class="flex justify-end gap-3">
                    <button type="button" onclick="closeBulkEditModal()" class="px-4 py-2 text-gray-600 hover:bg-gray-100 rounded-lg">Hủy</button>
                    <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-blue-800">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Stock Modal -->
<div id="edit-stock-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4">
        <div class="p-6 border-b border-gray-100">
            <h3 class="text-lg font-bold text-gray-800"><i class="fa-solid fa-boxes-stacked mr-2 text-primary"></i>Cập nhật tồn kho</h3>
        </div>
        <div class="p-6">
            <form id="edit-stock-form">
                <input type="hidden" id="edit-stock-product-id">
                <div class="mb-4">
                    <p class="text-sm text-gray-600 mb-2">Sản phẩm: <span id="edit-stock-product-name" class="font-semibold text-gray-800"></span></p>
                    <p class="text-sm text-gray-600 mb-4">SKU: <span id="edit-stock-product-sku" class="font-semibold text-gray-800"></span></p>
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Số lượng tồn kho</label>
                    <input type="number" id="edit-stock-value" min="0" class="w-full border border-gray-300 rounded-lg p-2.5 text-sm" required>
                </div>
                <div class="flex justify-end gap-3">
                    <button type="button" onclick="closeEditStockModal()" class="px-4 py-2 text-gray-600 hover:bg-gray-100 rounded-lg">Hủy</button>
                    <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-blue-800">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('partials/scripts') %>
<script>
    const token = localStorage.getItem('token');
    let currentPage = 1;
    let selectedItems = new Set();

    document.addEventListener('DOMContentLoaded', () => {
        if (!token) window.location.href = '/admin/login';

        loadCategoryFilter();
        loadInventoryStats();
        loadInventory();

        document.getElementById('search-inventory').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') loadInventory(1);
        });

        ['filter-category', 'filter-stock-status', 'sort-inventory', 'page-limit'].forEach(id => {
            document.getElementById(id).addEventListener('change', () => loadInventory(1));
        });

        document.getElementById('import-form').addEventListener('submit', handleImport);
        document.getElementById('bulk-edit-form').addEventListener('submit', handleBulkEdit);
        document.getElementById('edit-stock-form').addEventListener('submit', handleEditStock);
    });

    async function loadInventoryStats() {
        try {
            const res = await fetch('/api/v1/inventory/stats', { headers: { 'Authorization': `Bearer ${token}` } });
            const data = await res.json();
            if (data.success) {
                document.querySelector('[data-stat="totalProducts"]').textContent = data.data.totalProducts;
                document.querySelector('[data-stat="inStock"]').textContent = data.data.inStock;
                document.querySelector('[data-stat="lowStock"]').textContent = data.data.lowStock;
                document.querySelector('[data-stat="outOfStock"]').textContent = data.data.outOfStock;
                document.querySelector('[data-stat="negativeStock"]').textContent = data.data.negativeStock;
            }
        } catch (error) {
            console.error('Error loading inventory stats:', error);
        }
    }

    async function loadCategoryFilter() {
        try {
            const res = await fetch('/api/v1/categories', { headers: { 'Authorization': `Bearer ${token}` } });
            const data = await res.json();
            if (data.success) {
                const select = document.getElementById('filter-category');
                data.data.forEach(cat => {
                    select.innerHTML += `<option value="${cat._id}">${cat.name}</option>`;
                });
            }
        } catch (error) {
            console.error('Error loading categories:', error);
        }
    }

    async function loadInventory(page = 1) {
        currentPage = page;
        const params = new URLSearchParams();
        params.set('page', page);
        params.set('limit', document.getElementById('page-limit').value);

        const search = document.getElementById('search-inventory').value;
        if (search) params.set('search', search);

        const category = document.getElementById('filter-category').value;
        if (category) params.set('category', category);

        const stockStatus = document.getElementById('filter-stock-status').value;
        if (stockStatus) params.set('stockStatus', stockStatus);

        const sort = document.getElementById('sort-inventory').value;
        if (sort) params.set('sort', sort);

        try {
            const res = await fetch(`/api/v1/inventory?${params}`, { headers: { 'Authorization': `Bearer ${token}` } });
            const data = await res.json();
            if (data.success) {
                renderInventoryTable(data.data);
                renderPagination(data.pagination);
            }
        } catch (error) {
            console.error('Error loading inventory:', error);
            showToast('Lỗi khi tải dữ liệu tồn kho', 'error');
        }
    }

    function renderInventoryTable(products) {
        const tbody = document.getElementById('inventory-tbody');
        if (!products.length) {
            tbody.innerHTML = '<tr><td colspan="7" class="p-4 text-center text-gray-500">Không có sản phẩm nào</td></tr>';
            return;
        }

        tbody.innerHTML = products.map(product => {
            const stockClass = product.stock <= 0 ? 'text-red-600 font-bold' : product.stock <= 10 ? 'text-yellow-600 font-semibold' : 'text-green-600';
            const stockBadge = product.stock <= 0 ? 'bg-red-100 text-red-700' : product.stock <= 10 ? 'bg-yellow-100 text-yellow-700' : 'bg-green-100 text-green-700';
            const stockStatus = product.stock <= 0 ? 'Hết hàng' : product.stock <= 10 ? 'Sắp hết' : 'Còn hàng';

            return `
                <tr class="hover:bg-gray-50 ${product.stock <= 0 ? 'bg-red-50/30' : ''}">
                    <td class="p-4">
                        <input type="checkbox" class="inventory-checkbox w-4 h-4 text-primary border-gray-300 rounded" value="${product._id}" onchange="toggleSelection('${product._id}')">
                    </td>
                    <td class="p-4">
                        <p class="font-medium text-gray-800">${product.name}</p>
                    </td>
                    <td class="p-4 text-gray-600">${product.sku}</td>
                    <td class="p-4 text-gray-600">${product.category?.name || '-'}</td>
                    <td class="p-4 text-center">
                        <span class="${stockClass}">${product.stock}</span>
                    </td>
                    <td class="p-4 text-center">
                        <span class="px-2 py-1 rounded-full text-xs font-medium ${stockBadge}">${stockStatus}</span>
                    </td>
                    <td class="p-4 text-right">
                        <button onclick="openEditStockModal('${product._id}', '${product.name}', '${product.sku}', ${product.stock})" class="text-primary hover:text-blue-800 font-medium text-sm">
                            <i class="fa-solid fa-edit mr-1"></i> Sửa
                        </button>
                    </td>
                </tr>
            `;
        }).join('');
    }

    function renderPagination(pagination) {
        const { total, page, pages } = pagination;
        document.getElementById('pagination-info').textContent = `Hiển thị ${total} sản phẩm (Trang ${page}/${pages})`;

        const controls = document.getElementById('pagination-controls');
        if (pages <= 1) {
            controls.innerHTML = '';
            return;
        }

        let html = '';
        if (page > 1) html += `<button onclick="loadInventory(${page - 1})" class="px-3 py-1 rounded border hover:bg-gray-100">‹</button>`;
        
        const start = Math.max(1, page - 2);
        const end = Math.min(pages, page + 2);
        
        if (start > 1) html += `<button onclick="loadInventory(1)" class="px-3 py-1 rounded border hover:bg-gray-100">1</button>`;
        if (start > 2) html += `<span class="px-2">...</span>`;
        
        for (let i = start; i <= end; i++) {
            html += `<button onclick="loadInventory(${i})" class="px-3 py-1 rounded border ${i === page ? 'bg-primary text-white' : 'hover:bg-gray-100'}">${i}</button>`;
        }
        
        if (end < pages - 1) html += `<span class="px-2">...</span>`;
        if (end < pages) html += `<button onclick="loadInventory(${pages})" class="px-3 py-1 rounded border hover:bg-gray-100">${pages}</button>`;
        
        if (page < pages) html += `<button onclick="loadInventory(${page + 1})" class="px-3 py-1 rounded border hover:bg-gray-100">›</button>`;
        
        controls.innerHTML = html;
    }

    function toggleSelectAll(checked) {
        document.querySelectorAll('.inventory-checkbox').forEach(cb => {
            cb.checked = checked;
            if (checked) selectedItems.add(cb.value);
            else selectedItems.delete(cb.value);
        });
        updateBulkActionBar();
    }

    function toggleSelection(id) {
        if (selectedItems.has(id)) selectedItems.delete(id);
        else selectedItems.add(id);
        updateBulkActionBar();
    }

    function updateBulkActionBar() {
        const bar = document.getElementById('bulk-action-bar');
        const count = document.getElementById('selected-count');
        if (selectedItems.size > 0) {
            bar.classList.remove('hidden');
            count.textContent = `${selectedItems.size} sản phẩm được chọn`;
        } else {
            bar.classList.add('hidden');
        }
    }

    function quickFilter(key, value) {
        if (key === 'stockStatus') {
            document.getElementById('filter-stock-status').value = value;
        }
        loadInventory(1);
    }

    function resetFilters() {
        document.getElementById('search-inventory').value = '';
        document.getElementById('filter-category').value = '';
        document.getElementById('filter-stock-status').value = '';
        document.getElementById('sort-inventory').value = 'updated_desc';
        loadInventory(1);
    }

    function openImportModal() {
        document.getElementById('import-modal').classList.remove('hidden');
        document.getElementById('import-modal').classList.add('flex');
    }

    function closeImportModal() {
        document.getElementById('import-modal').classList.add('hidden');
        document.getElementById('import-modal').classList.remove('flex');
        document.getElementById('import-form').reset();
    }

    async function handleImport(e) {
        e.preventDefault();
        const fileInput = document.getElementById('import-file');
        if (!fileInput.files[0]) {
            showToast('Vui lòng chọn file CSV', 'error');
            return;
        }

        const formData = new FormData();
        formData.append('file', fileInput.files[0]);

        try {
            const res = await fetch('/api/v1/inventory/import', {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}` },
                body: formData
            });
            const data = await res.json();
            
            if (data.success) {
                showToast(data.message, 'success');
                closeImportModal();
                loadInventoryStats();
                loadInventory(currentPage);
            } else {
                showToast(data.message, 'error');
            }
        } catch (error) {
            showToast('Lỗi khi import tồn kho', 'error');
        }
    }

    function openBulkEditModal() {
        if (selectedItems.size === 0) {
            showToast('Vui lòng chọn ít nhất một sản phẩm', 'warning');
            return;
        }
        document.getElementById('bulk-edit-modal').classList.remove('hidden');
        document.getElementById('bulk-edit-modal').classList.add('flex');
    }

    function closeBulkEditModal() {
        document.getElementById('bulk-edit-modal').classList.add('hidden');
        document.getElementById('bulk-edit-modal').classList.remove('flex');
        document.getElementById('bulk-edit-form').reset();
    }

    async function handleBulkEdit(e) {
        e.preventDefault();
        const stock = document.getElementById('bulk-stock').value;

        const updates = Array.from(selectedItems).map(id => ({
            productId: id,
            stock: stock ? parseInt(stock) : undefined
        })).filter(u => u.stock !== undefined);

        if (updates.length === 0) {
            showToast('Vui lòng nhập số lượng tồn kho', 'warning');
            return;
        }

        try {
            const res = await fetch('/api/v1/inventory/bulk', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ updates })
            });
            const data = await res.json();
            
            if (data.success) {
                showToast(data.message, 'success');
                closeBulkEditModal();
                selectedItems.clear();
                updateBulkActionBar();
                loadInventoryStats();
                loadInventory(currentPage);
            } else {
                showToast(data.message, 'error');
            }
        } catch (error) {
            showToast('Lỗi khi cập nhật hàng loạt', 'error');
        }
    }

    function openEditStockModal(id, name, sku, stock) {
        document.getElementById('edit-stock-product-id').value = id;
        document.getElementById('edit-stock-product-name').textContent = name;
        document.getElementById('edit-stock-product-sku').textContent = sku;
        document.getElementById('edit-stock-value').value = stock;
        document.getElementById('edit-stock-modal').classList.remove('hidden');
        document.getElementById('edit-stock-modal').classList.add('flex');
    }

    function closeEditStockModal() {
        document.getElementById('edit-stock-modal').classList.add('hidden');
        document.getElementById('edit-stock-modal').classList.remove('flex');
    }

    async function handleEditStock(e) {
        e.preventDefault();
        const productId = document.getElementById('edit-stock-product-id').value;
        const stock = parseInt(document.getElementById('edit-stock-value').value);

        try {
            const res = await fetch(`/api/v1/inventory/${productId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ stock })
            });
            const data = await res.json();
            
            if (data.success) {
                showToast('Cập nhật tồn kho thành công', 'success');
                closeEditStockModal();
                loadInventoryStats();
                loadInventory(currentPage);
            } else {
                showToast(data.message, 'error');
            }
        } catch (error) {
            showToast('Lỗi khi cập nhật tồn kho', 'error');
        }
    }

    function exportInventory() {
        const params = new URLSearchParams();
        const search = document.getElementById('search-inventory').value;
        if (search) params.set('search', search);
        
        const category = document.getElementById('filter-category').value;
        if (category) params.set('category', category);

        window.location.href = `/api/v1/inventory/export?${params}`;
    }

    function showToast(message, type = 'info') {
        const container = document.getElementById('admin-toast-container');
        const toast = document.createElement('div');
        const bgColor = type === 'success' ? 'bg-green-500' : type === 'error' ? 'bg-red-500' : type === 'warning' ? 'bg-yellow-500' : 'bg-blue-500';
        toast.className = `${bgColor} text-white px-4 py-3 rounded-lg shadow-lg flex items-center gap-2 animate-slide-in`;
        toast.innerHTML = `<span>${message}</span>`;
        container.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }
</script>

<style>
    @keyframes slide-in {
        from { transform: translateX(100%); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }
    .animate-slide-in { animation: slide-in 0.3s ease-out; }
</style>